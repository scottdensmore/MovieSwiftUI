// Shared project defaults. Local developers override these via
// ../DeveloperSettings.xcconfig, which is gitignored.

DEVELOPMENT_TEAM =
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_STYLE = Automatic
ORGANIZATION_IDENTIFIER = com.example
TMDB_API_KEY =

// Base URL of the TMDB-compatible HTTP service this build talks
// to. Default is TMDB direct; override in DeveloperSettings.xcconfig
// to point at a proxy that hides the API key (e.g. a Cloudflare
// Worker that attaches the key server-side and forwards to TMDB).
// The proxy contract is "drop in /3-style endpoints". URL values
// in xcconfig need the `//` escaped per Xcode parsing rules.
TMDB_BASE_URL = https:/$()/api.themoviedb.org/3

// Optional. URL string for the hosted privacy policy displayed in
// Settings > About. Required for App Store submission. Override
// in DeveloperSettings.xcconfig with the production URL once it's
// hosted; until then the Settings row is hidden so the placeholder
// doesn't ship.
PRIVACY_POLICY_URL =

// Localization: turn on String Catalog auto-extraction so SwiftUI
// `Text("...")` literals (and other LocalizedStringKey-accepting
// APIs) populate Localizable.xcstrings on each build.
//
// SWIFT_EMIT_LOC_STRINGS = YES makes the Swift compiler emit a
// per-module .stringsdata file alongside the build artifacts.
// LOCALIZATION_PREFERS_STRING_CATALOGS = YES tells the build
// system to merge that .stringsdata into the project's
// Localizable.xcstrings instead of generating legacy .strings.
SWIFT_EMIT_LOC_STRINGS = YES
LOCALIZATION_PREFERS_STRING_CATALOGS = YES

#include? "../DeveloperSettings.xcconfig"
