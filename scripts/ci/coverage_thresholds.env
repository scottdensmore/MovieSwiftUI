# Shared CI coverage thresholds (lower bounds).
# Environment variables provided by CI take precedence over these defaults.

: "${BACKEND_MIN_LINE_COVERAGE:=76.1}"
# `FLUX_MIN` covers the MovieSwiftFluxCore domain package; `FLUX_PACKAGE_MIN`
# covers the standalone `Flux` Redux-primitives package.
: "${FLUX_MIN_LINE_COVERAGE:=52.2}"
: "${FLUX_PACKAGE_MIN_LINE_COVERAGE:=85.0}"
: "${APP_MIN_LINE_COVERAGE:=6.0}"
: "${APP_COVERAGE_TARGET:=MovieSwift.app}"
