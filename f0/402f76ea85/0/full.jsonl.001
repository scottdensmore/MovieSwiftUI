{"parentUuid":"2947a011-f3f9-4961-a52e-c205103d32ed","isSidechain":false,"promptId":"af759ad8-76cc-4b58-b2d3-322690ab2306","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PBEczchNPD7Z3DfiPZ5riz","type":"tool_result","content":"1\timport Testing\n2\t@testable import MovieSwiftFluxCore\n3\t\n4\t@Suite struct ReducerTests {\n5\t    @Test func moviesReducerSetMovieMenuListPageOneReplacesList() {\n6\t        var state = MoviesState()\n7\t        state.moviesList[.popular] = [999]\n8\t\n9\t        let response = paginated([makeMovie(id: 1), makeMovie(id: 2)])\n10\t        let action = MoviesActions.SetMovieMenuList(page: 1, list: .popular, response: response)\n11\t\n12\t        let reduced = moviesStateReducer(state: state, action: action)\n13\t\n14\t        #expect((reduced.moviesList[.popular] ?? []) == [1, 2])\n15\t        #expect(reduced.movies[1]?.id == 1)\n16\t        #expect(reduced.movies[2]?.id == 2)\n17\t    }\n18\t\n19\t    @Test func moviesReducerSetMovieMenuListPageTwoAppendsList() {\n20\t        var state = MoviesState()\n21\t        state.moviesList[.trending] = [1]\n22\t\n23\t        let response = paginated([makeMovie(id: 2), makeMovie(id: 3)])\n24\t        let action = MoviesActions.SetMovieMenuList(page: 2, list: .trending, response: response)\n25\t\n26\t        let reduced = moviesStateReducer(state: state, action: action)\n27\t\n28\t        #expect((reduced.moviesList[.trending] ?? []) == [1, 2, 3])\n29\t    }\n30\t\n31\t    @Test func moviesReducerAddToWishlistMovesMovieAndAddsMetaTimestamp() {\n32\t        var state = MoviesState()\n33\t        state.seenlist.insert(42)\n34\t\n35\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddToWishlist(movie: 42))\n36\t\n37\t        #expect(reduced.wishlist.contains(42))\n38\t        #expect(!(reduced.seenlist.contains(42)))\n39\t        #expect(reduced.moviesUserMeta[42]?.addedToList != nil)\n40\t    }\n41\t\n42\t    @Test func moviesReducerSetRandomDiscoverPrependsWhenBelowLimit() {\n43\t        var state = MoviesState()\n44\t        state.discover = [100, 101]\n45\t        let filter = DiscoverFilter(year: 1990, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: 12, region: \"US\")\n46\t        let response = paginated([makeMovie(id: 1), makeMovie(id: 2)])\n47\t\n48\t        let reduced = moviesStateReducer(\n49\t            state: state,\n50\t            action: MoviesActions.SetRandomDiscover(filter: filter, response: response)\n51\t        )\n52\t\n53\t        #expect(reduced.discover == [1, 2, 100, 101])\n54\t        #expect(reduced.movies[1]?.id == 1)\n55\t        #expect(reduced.movies[2]?.id == 2)\n56\t        #expect(reduced.discoverFilter?.year == filter.year)\n57\t        #expect(reduced.discoverFilter?.sort == filter.sort)\n58\t        #expect(reduced.discoverFilter?.genre == filter.genre)\n59\t        #expect(reduced.discoverFilter?.region == filter.region)\n60\t    }\n61\t\n62\t    @Test func moviesReducerSetRandomDiscoverDoesNotPrependWhenAtLimit() {\n63\t        var state = MoviesState()\n64\t        state.discover = Array(1...10)\n65\t        let filter = DiscoverFilter(year: 1990, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n66\t        let response = paginated([makeMovie(id: 99)])\n67\t\n68\t        let reduced = moviesStateReducer(\n69\t            state: state,\n70\t            action: MoviesActions.SetRandomDiscover(filter: filter, response: response)\n71\t        )\n72\t\n73\t        #expect(reduced.discover == Array(1...10))\n74\t        #expect(reduced.movies[99]?.id == 99)\n75\t        #expect(reduced.discoverFilter?.year == 1990)\n76\t    }\n77\t\n78\t    @Test func moviesReducerSetActiveDiscoverFilterUpdatesFilterImmediately() {\n79\t        var state = MoviesState()\n80\t        state.discoverFilter = nil\n81\t        let filter = DiscoverFilter(year: 2001, startYear: 1990, endYear: 1999, sort: \"popularity.desc\", genre: 28, region: \"US\")\n82\t\n83\t        let reduced = moviesStateReducer(\n84\t            state: state,\n85\t            action: MoviesActions.SetActiveDiscoverFilter(filter: filter)\n86\t        )\n87\t\n88\t        #expect(reduced.discoverFilter?.startYear == 1990)\n89\t        #expect(reduced.discoverFilter?.endYear == 1999)\n90\t        #expect(reduced.discoverFilter?.genre == 28)\n91\t        #expect(reduced.discoverFilter?.region == \"US\")\n92\t    }\n93\t\n94\t    @Test func moviesReducerSetGenresInsertsRandomGenreFirst() {\n95\t        let genres = [Genre(id: 7, name: \"Drama\"), Genre(id: 8, name: \"Comedy\")]\n96\t\n97\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetGenres(genres: genres))\n98\t\n99\t        #expect(reduced.genres.first?.id == -1)\n100\t        #expect(reduced.genres.first?.name == \"Random\")\n101\t        #expect(reduced.genres.dropFirst().map(\\.id) == [7, 8])\n102\t    }\n103\t\n104\t    @Test func moviesReducerAddMoviesToCustomListMergesIntoExistingList() {\n105\t        let existing = CustomList(id: 9, name: \"Favorites\", cover: nil, movies: [1, 2])\n106\t        var state = MoviesState()\n107\t        state.customLists[9] = existing\n108\t\n109\t        let reduced = moviesStateReducer(\n110\t            state: state,\n111\t            action: MoviesActions.AddMoviesToCustomList(list: 9, movies: [2, 3, 4])\n112\t        )\n113\t\n114\t        #expect(reduced.customLists[9]?.movies == Set([1, 2, 3, 4]))\n115\t    }\n116\t\n117\t    @Test func moviesReducerEditCustomListUpdatesOnlyProvidedFields() {\n118\t        let existing = CustomList(id: 4, name: \"Weekend\", cover: 7, movies: [7, 8])\n119\t        var state = MoviesState()\n120\t        state.customLists[4] = existing\n121\t\n122\t        let renamed = moviesStateReducer(\n123\t            state: state,\n124\t            action: MoviesActions.EditCustomList(list: 4, title: \"Weeknight\", cover: nil)\n125\t        )\n126\t        #expect(renamed.customLists[4]?.name == \"Weeknight\")\n127\t        #expect(renamed.customLists[4]?.cover == 7)\n128\t\n129\t        let recoved = moviesStateReducer(\n130\t            state: renamed,\n131\t            action: MoviesActions.EditCustomList(list: 4, title: nil, cover: 11)\n132\t        )\n133\t        #expect(recoved.customLists[4]?.name == \"Weeknight\")\n134\t        #expect(recoved.customLists[4]?.cover == 11)\n135\t    }\n136\t\n137\t    @Test func peopleReducerSetDetailPreservesExistingMetadataFields() {\n138\t        let knownFor = [People.KnownFor(id: 90, original_title: \"Old\", poster_path: \"/old.jpg\")]\n139\t        let images = [ImageData(aspect_ratio: 1.0, file_path: \"/img.jpg\", height: 10, width: 10)]\n140\t\n141\t        var state = PeoplesState()\n142\t        state.peoples[5] = makePeople(id: 5, name: \"Old Name\", character: \"Old Char\", department: \"Directing\", knownFor: knownFor, images: images)\n143\t\n144\t        let incoming = makePeople(id: 5, name: \"New Name\", character: nil, department: nil, knownFor: nil, images: nil)\n145\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetDetail(person: incoming))\n146\t\n147\t        #expect(reduced.peoples[5]?.name == \"New Name\")\n148\t        // SetDetail only preserves known_for and images from the existing record;\n149\t        // character and department come from the incoming person as-is.\n150\t        #expect(reduced.peoples[5]?.character == nil)\n151\t        #expect(reduced.peoples[5]?.department == nil)\n152\t        #expect(reduced.peoples[5]?.known_for?.first?.id == 90)\n153\t        #expect(reduced.peoples[5]?.images?.first?.file_path == \"/img.jpg\")\n154\t    }\n155\t\n156\t    @Test func peopleReducerSetMovieCastsMergesPeopleAndIndexesMovie() {\n157\t        let cast = makePeople(id: 1, name: \"Cast Member\")\n158\t        let crew = makePeople(id: 2, name: \"Crew Member\")\n159\t        let response = CastResponse(id: 100, cast: [cast], crew: [crew])\n160\t\n161\t        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetMovieCasts(movie: 99, response: response))\n162\t\n163\t        #expect(reduced.peoples[1]?.name == \"Cast Member\")\n164\t        #expect(reduced.peoples[2]?.name == \"Crew Member\")\n165\t        #expect(reduced.peoplesMovies[99] == Set([1, 2]))\n166\t    }\n167\t\n168\t    @Test func peopleReducerSetPeopleCreditsStoresCharacterAndDepartmentMaps() {\n169\t        let castMovie = makeMovie(id: 10, character: \"Hero\", department: nil)\n170\t        let castMovieWithoutCharacter = makeMovie(id: 11, character: nil, department: nil)\n171\t        let crewMovie = makeMovie(id: 20, character: nil, department: \"Directing\")\n172\t        let crewMovieWithoutDepartment = makeMovie(id: 21, character: nil, department: nil)\n173\t\n174\t        let response = PeopleActions.PeopleCreditsResponse(\n175\t            cast: [castMovie, castMovieWithoutCharacter],\n176\t            crew: [crewMovie, crewMovieWithoutDepartment]\n177\t        )\n178\t\n179\t        let reduced = peoplesStateReducer(\n180\t            state: PeoplesState(),\n181\t            action: PeopleActions.SetPeopleCredits(people: 7, response: response)\n182\t        )\n183\t\n184\t        #expect(reduced.casts[7]?[10] == \"Hero\")\n185\t        #expect(reduced.casts[7]?[11] == nil)\n186\t        #expect(reduced.crews[7]?[20] == \"Directing\")\n187\t        #expect(reduced.crews[7]?[21] == nil)\n188\t    }\n189\t\n190\t    @Test func appReducerRoutesMovieActionToMoviesState() {\n191\t        var state = AppState()\n192\t        state.moviesState.seenlist.insert(5)\n193\t\n194\t        let reduced = appStateReducer(state: state, action: MoviesActions.AddToWishlist(movie: 5))\n195\t\n196\t        #expect(reduced.moviesState.wishlist.contains(5))\n197\t        #expect(!(reduced.moviesState.seenlist.contains(5)))\n198\t    }\n199\t\n200\t    @Test func appReducerRoutesPeopleActionToPeoplesState() {\n201\t        let reduced = appStateReducer(state: AppState(), action: PeopleActions.AddToFanClub(people: 55))\n202\t\n203\t        #expect(reduced.peoplesState.fanClub.contains(55))\n204\t    }\n205\t\n206\t    // MARK: - MoviesReducer: SetDetail\n207\t\n208\t    @Test func moviesReducerSetDetailStoresMovieAndMarksDetailed() {\n209\t        let movie = makeMovie(id: 42)\n210\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetDetail(movie: 42, response: movie))\n211\t\n212\t        #expect(reduced.movies[42]?.id == 42)\n213\t        #expect(reduced.detailed.contains(42))\n214\t    }\n215\t\n216\t    // MARK: - MoviesReducer: SetRecommended / SetSimilar\n217\t\n218\t    @Test func moviesReducerSetRecommendedMergesMoviesAndMarksLoaded() {\n219\t        let response = paginated([makeMovie(id: 10), makeMovie(id: 11)])\n220\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetRecommended(movie: 5, response: response))\n221\t\n222\t        #expect(reduced.recommended[5] == [10, 11])\n223\t        #expect(reduced.recommendedLoaded.contains(5))\n224\t        #expect(reduced.movies[10] != nil)\n225\t        #expect(reduced.movies[11] != nil)\n226\t    }\n227\t\n228\t    @Test func moviesReducerSetSimilarMergesMoviesAndMarksLoaded() {\n229\t        let response = paginated([makeMovie(id: 20)])\n230\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetSimilar(movie: 6, response: response))\n231\t\n232\t        #expect(reduced.similar[6] == [20])\n233\t        #expect(reduced.similarLoaded.contains(6))\n234\t    }\n235\t\n236\t    // MARK: - MoviesReducer: SetVideos\n237\t\n238\t    @Test func moviesReducerSetVideosStoresResultsAndMarksLoaded() {\n239\t        let video = Video(id: \"v1\", name: \"Trailer\", site: \"YouTube\", key: \"abc\", type: \"Trailer\")\n240\t        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [video])\n241\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetVideos(movie: 7, response: response))\n242\t\n243\t        #expect(reduced.videos[7]?.first?.key == \"abc\")\n244\t        #expect(reduced.videosLoaded.contains(7))\n245\t    }\n246\t\n247\t    // MARK: - MoviesReducer: SetSearch\n248\t\n249\t    @Test func moviesReducerSetSearchPageOneReplacesList() {\n250\t        var state = MoviesState()\n251\t        state.search[\"old\"] = [999]\n252\t\n253\t        let response = paginated([makeMovie(id: 1)])\n254\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetSearch(query: \"old\", page: 1, response: response))\n255\t\n256\t        #expect(reduced.search[\"old\"] == [1])\n257\t    }\n258\t\n259\t    @Test func moviesReducerSetSearchPageTwoAppendsList() {\n260\t        var state = MoviesState()\n261\t        state.search[\"q\"] = [1]\n262\t\n263\t        let response = paginated([makeMovie(id: 2)])\n264\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetSearch(query: \"q\", page: 2, response: response))\n265\t\n266\t        #expect(reduced.search[\"q\"] == [1, 2])\n267\t    }\n268\t\n269\t    // MARK: - MoviesReducer: SetSearchKeyword\n270\t\n271\t    @Test func moviesReducerSetSearchKeywordStoresKeywords() {\n272\t        let keywords = [Keyword(id: 1, name: \"neo-noir\"), Keyword(id: 2, name: \"heist\")]\n273\t        let response = PaginatedResponse(page: 1, total_results: 2, total_pages: 1, results: keywords)\n274\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetSearchKeyword(query: \"noir\", response: response))\n275\t\n276\t        #expect(reduced.searchKeywords[\"noir\"]?.count == 2)\n277\t        #expect(reduced.searchKeywords[\"noir\"]?.first?.name == \"neo-noir\")\n278\t    }\n279\t\n280\t    // MARK: - MoviesReducer: Wishlist / Seenlist\n281\t\n282\t    @Test func moviesReducerRemoveFromWishlistRemovesMovie() {\n283\t        var state = MoviesState()\n284\t        state.wishlist.insert(42)\n285\t\n286\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveFromWishlist(movie: 42))\n287\t\n288\t        #expect(!(reduced.wishlist.contains(42)))\n289\t    }\n290\t\n291\t    @Test func moviesReducerAddToSeenListMovesFromWishlistAndAddsTimestamp() {\n292\t        var state = MoviesState()\n293\t        state.wishlist.insert(42)\n294\t\n295\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddToSeenList(movie: 42))\n296\t\n297\t        #expect(reduced.seenlist.contains(42))\n298\t        #expect(!(reduced.wishlist.contains(42)))\n299\t        #expect(reduced.moviesUserMeta[42]?.addedToList != nil)\n300\t    }\n301\t\n302\t    @Test func moviesReducerRemoveFromSeenListRemovesMovie() {\n303\t        var state = MoviesState()\n304\t        state.seenlist.insert(42)\n305\t\n306\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveFromSeenList(movie: 42))\n307\t\n308\t        #expect(!(reduced.seenlist.contains(42)))\n309\t    }\n310\t\n311\t    // MARK: - MoviesReducer: CustomList operations\n312\t\n313\t    @Test func moviesReducerAddMovieToCustomListInsertsMovie() {\n314\t        var state = MoviesState()\n315\t        state.customLists[1] = CustomList(id: 1, name: \"Favorites\", cover: nil, movies: [10])\n316\t\n317\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddMovieToCustomList(list: 1, movie: 20))\n318\t\n319\t        #expect(reduced.customLists[1]?.movies.contains(20) == true)\n320\t        #expect(reduced.customLists[1]?.movies.contains(10) == true)\n321\t    }\n322\t\n323\t    @Test func moviesReducerRemoveMovieFromCustomListRemovesMovie() {\n324\t        var state = MoviesState()\n325\t        state.customLists[1] = CustomList(id: 1, name: \"Favorites\", cover: nil, movies: [10, 20])\n326\t\n327\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveMovieFromCustomList(list: 1, movie: 10))\n328\t\n329\t        #expect(!(reduced.customLists[1]?.movies.contains(10) == true))\n330\t        #expect(reduced.customLists[1]?.movies.contains(20) == true)\n331\t    }\n332\t\n333\t    @Test func moviesReducerAddCustomListStoresList() {\n334\t        let list = CustomList(id: 5, name: \"Watch Later\", cover: nil, movies: [])\n335\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.AddCustomList(list: list))\n336\t\n337\t        #expect(reduced.customLists[5]?.name == \"Watch Later\")\n338\t    }\n339\t\n340\t    @Test func moviesReducerRemoveCustomListNilifiesEntry() {\n341\t        var state = MoviesState()\n342\t        state.customLists[5] = CustomList(id: 5, name: \"Old\", cover: nil, movies: [])\n343\t\n344\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveCustomList(list: 5))\n345\t\n346\t        #expect(reduced.customLists[5] == nil)\n347\t    }\n348\t\n349\t    // MARK: - MoviesReducer: Genre / Crew / Keyword movies\n350\t\n351\t    @Test func moviesReducerSetMovieForGenrePageOneReplacesList() {\n352\t        var state = MoviesState()\n353\t        state.withGenre[28] = [999]\n354\t\n355\t        let genre = Genre(id: 28, name: \"Action\")\n356\t        let response = paginated([makeMovie(id: 1)])\n357\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieForGenre(genre: genre, page: 1, response: response))\n358\t\n359\t        #expect(reduced.withGenre[28] == [1])\n360\t    }\n361\t\n362\t    @Test func moviesReducerSetMovieForGenrePageTwoAppendsList() {\n363\t        var state = MoviesState()\n364\t        state.withGenre[28] = [1]\n365\t\n366\t        let genre = Genre(id: 28, name: \"Action\")\n367\t        let response = paginated([makeMovie(id: 2)])\n368\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieForGenre(genre: genre, page: 2, response: response))\n369\t\n370\t        #expect(reduced.withGenre[28] == [1, 2])\n371\t    }\n372\t\n373\t    @Test func moviesReducerSetMovieWithCrewStoresResults() {\n374\t        let response = paginated([makeMovie(id: 10)])\n375\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetMovieWithCrew(crew: 15, response: response))\n376\t\n377\t        #expect(reduced.withCrew[15] == [10])\n378\t    }\n379\t\n380\t    @Test func moviesReducerSetMovieWithKeywordPageOneReplacesList() {\n381\t        var state = MoviesState()\n382\t        state.withKeywords[50] = [999]\n383\t\n384\t        let response = paginated([makeMovie(id: 1)])\n385\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieWithKeyword(keyword: 50, page: 1, response: response))\n386\t\n387\t        #expect(reduced.withKeywords[50] == [1])\n388\t    }\n389\t\n390\t    @Test func moviesReducerSetMovieWithKeywordPageTwoAppendsList() {\n391\t        var state = MoviesState()\n392\t        state.withKeywords[50] = [1]\n393\t\n394\t        let response = paginated([makeMovie(id: 2)])\n395\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieWithKeyword(keyword: 50, page: 2, response: response))\n396\t\n397\t        #expect(reduced.withKeywords[50] == [1, 2])\n398\t    }\n399\t\n400\t    // MARK: - MoviesReducer: Reviews\n401\t\n402\t    @Test func moviesReducerSetMovieReviewsStoresResultsAndMarksLoaded() {\n403\t        let review = Review(id: \"r1\", author: \"Critic\", content: \"Great\")\n404\t        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [review])\n405\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetMovieReviews(movie: 8, response: response))\n406\t\n407\t        #expect(reduced.reviews[8]?.first?.author == \"Critic\")\n408\t        #expect(reduced.reviewsLoaded.contains(8))\n409\t    }\n410\t\n411\t    // MARK: - MoviesReducer: Discover operations\n412\t\n413\t    @Test func moviesReducerPopRandomDiscoverRemovesLastElement() {\n414\t        var state = MoviesState()\n415\t        state.discover = [1, 2, 3]\n416\t\n417\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.PopRandromDiscover())\n418\t\n419\t        #expect(reduced.discover == [1, 2])\n420\t    }\n421\t\n422\t    @Test func moviesReducerPushRandomDiscoverAppendsMovie() {\n423\t        var state = MoviesState()\n424\t        state.discover = [1, 2]\n425\t\n426\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.PushRandomDiscover(movie: 3))\n427\t\n428\t        #expect(reduced.discover == [1, 2, 3])\n429\t    }\n430\t\n431\t    @Test func moviesReducerResetRandomDiscoverClearsFilterAndList() {\n432\t        var state = MoviesState()\n433\t        state.discover = [1, 2, 3]\n434\t        state.discoverFilter = DiscoverFilter(year: 2000, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n435\t\n436\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.ResetRandomDiscover())\n437\t\n438\t        #expect(reduced.discover.isEmpty)\n439\t        #expect(reduced.discoverFilter == nil)\n440\t    }\n441\t\n442\t    @Test func moviesReducerSaveDiscoverFilterAppendsFilter() {\n443\t        var state = MoviesState()\n444\t        let filter1 = DiscoverFilter(year: 2000, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n445\t        state.savedDiscoverFilters = [filter1]\n446\t\n447\t        let filter2 = DiscoverFilter(year: 2010, startYear: nil, endYear: nil, sort: \"vote_average.desc\", genre: 28, region: \"US\")\n448\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.SaveDiscoverFilter(filter: filter2))\n449\t\n450\t        #expect(reduced.savedDiscoverFilters.count == 2)\n451\t        #expect(reduced.savedDiscoverFilters.last?.year == 2010)\n452\t    }\n453\t\n454\t    @Test func moviesReducerClearSavedDiscoverFiltersEmptiesArray() {\n455\t        var state = MoviesState()\n456\t        let filter = DiscoverFilter(year: 2000, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n457\t        state.savedDiscoverFilters = [filter]\n458\t\n459\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.ClearSavedDiscoverFilters())\n460\t\n461\t        #expect(reduced.savedDiscoverFilters.isEmpty)\n462\t    }\n463\t\n464\t    // MARK: - MoviesReducer: Cross-reducer (PeopleCredits merges movies)\n465\t\n466\t    @Test func moviesReducerPeopleCreditsAlsoMergesMoviesIntoMoviesState() {\n467\t        let castMovie = makeMovie(id: 10)\n468\t        let crewMovie = makeMovie(id: 20)\n469\t        let response = PeopleActions.PeopleCreditsResponse(cast: [castMovie], crew: [crewMovie])\n470\t\n471\t        let reduced = moviesStateReducer(state: MoviesState(), action: PeopleActions.SetPeopleCredits(people: 7, response: response))\n472\t\n473\t        #expect(reduced.movies[10] != nil)\n474\t        #expect(reduced.movies[20] != nil)\n475\t    }\n476\t\n477\t    // MARK: - PeopleReducer: Search\n478\t\n479\t    @Test func peopleReducerSetSearchPageOneReplacesList() {\n480\t        var state = PeoplesState()\n481\t        state.search[\"old\"] = [999]\n482\t\n483\t        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 1, name: \"A\")])\n484\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetSearch(query: \"old\", page: 1, response: response))\n485\t\n486\t        #expect(reduced.search[\"old\"] == [1])\n487\t    }\n488\t\n489\t    @Test func peopleReducerSetSearchPageTwoAppendsList() {\n490\t        var state = PeoplesState()\n491\t        state.search[\"q\"] = [1]\n492\t\n493\t        let response = PaginatedResponse(page: 2, total_results: 2, total_pages: 2, results: [makePeople(id: 2, name: \"B\")])\n494\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetSearch(query: \"q\", page: 2, response: response))\n495\t\n496\t        #expect(reduced.search[\"q\"] == [1, 2])\n497\t    }\n498\t\n499\t    // MARK: - PeopleReducer: Popular\n500\t\n501\t    @Test func peopleReducerSetPopularPageOneReplacesList() {\n502\t        var state = PeoplesState()\n503\t        state.popular = [999]\n504\t        state.popularLoading = true\n505\t\n506\t        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 1, name: \"A\")])\n507\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetPopular(page: 1, response: response))\n508\t\n509\t        #expect(reduced.popular == [1])\n510\t        #expect(!(reduced.popularLoading))\n511\t        #expect(reduced.popularInitialLoadCompleted)\n512\t    }\n513\t\n514\t    @Test func peopleReducerSetPopularPageTwoAppendsUnique() {\n515\t        var state = PeoplesState()\n516\t        state.popular = [1, 2]\n517\t\n518\t        let response = PaginatedResponse(page: 2, total_results: 3, total_pages: 2, results: [makePeople(id: 2, name: \"B\"), makePeople(id: 3, name: \"C\")])\n519\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetPopular(page: 2, response: response))\n520\t\n521\t        #expect(reduced.popular == [1, 2, 3])\n522\t    }\n523\t\n524\t    // MARK: - PeopleReducer: PopularRequestStarted / Failed\n525\t\n526\t    @Test func peopleReducerPopularRequestStartedSetsLoadingState() {\n527\t        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.PopularRequestStarted(page: 1))\n528\t\n529\t        #expect(reduced.popularLoading)\n530\t        #expect(!(reduced.popularLoadFailed))\n531\t        #expect(!(reduced.popularInitialLoadCompleted))\n532\t    }\n533\t\n534\t    @Test func peopleReducerPopularRequestFailedSetsFailedState() {\n535\t        var state = PeoplesState()\n536\t        state.popularLoading = true\n537\t\n538\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.PopularRequestFailed(page: 1))\n539\t\n540\t        #expect(!(reduced.popularLoading))\n541\t        #expect(reduced.popularLoadFailed)\n542\t        #expect(reduced.popularInitialLoadCompleted)\n543\t    }\n544\t\n545\t    // MARK: - PeopleReducer: FanClub\n546\t\n547\t    @Test func peopleReducerAddToFanClubInsertsPeopleId() {\n548\t        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.AddToFanClub(people: 55))\n549\t\n550\t        #expect(reduced.fanClub.contains(55))\n551\t    }\n552\t\n553\t    @Test func peopleReducerRemoveFromFanClubRemovesPeopleId() {\n554\t        var state = PeoplesState()\n555\t        state.fanClub.insert(55)\n556\t\n557\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.RemoveFromFanClub(people: 55))\n558\t\n559\t        #expect(!(reduced.fanClub.contains(55)))\n560\t    }\n561\t\n562\t    // MARK: - PeopleReducer: SetImages\n563\t\n564\t    @Test func peopleReducerSetImagesStoresImagesAndMarksLoaded() {\n565\t        let images = [ImageData(aspect_ratio: 0.67, file_path: \"/img.jpg\", height: 300, width: 200)]\n566\t        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetImages(people: 7, images: images))\n567\t\n568\t        #expect(reduced.peoples[7]?.images?.first?.file_path == \"/img.jpg\")\n569\t        #expect(reduced.imagesLoaded.contains(7))\n570\t    }\n571\t\n572\t    // MARK: - PeopleReducer: SetDetail new person\n573\t\n574\t    @Test func peopleReducerSetDetailNewPersonStoresDirectly() {\n575\t        let person = makePeople(id: 10, name: \"New Person\")\n576\t        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetDetail(person: person))\n577\t\n578\t        #expect(reduced.peoples[10]?.name == \"New Person\")\n579\t        #expect(reduced.detailed.contains(10))\n580\t    }\n581\t\n582\t    private func paginated<T: Codable>(_ values: [T]) -> PaginatedResponse<T> {\n583\t        PaginatedResponse(page: 1, total_results: values.count, total_pages: 1, results: values)\n584\t    }\n585\t\n586\t    private func makeMovie(id: Int, character: String? = nil, department: String? = nil) -> Movie {\n587\t        Movie(\n588\t            id: id,\n589\t            original_title: \"Original \\(id)\",\n590\t            title: \"Title \\(id)\",\n591\t            overview: \"Overview \\(id)\",\n592\t            poster_path: nil,\n593\t            backdrop_path: nil,\n594\t            popularity: 1.0,\n595\t            vote_average: 2.0,\n596\t            vote_count: 3,\n597\t            release_date: \"2020-01-01\",\n598\t            genres: nil,\n599\t            runtime: nil,\n600\t            status: nil,\n601\t            video: false,\n602\t            keywords: nil,\n603\t            images: nil,\n604\t            production_countries: nil,\n605\t            character: character,\n606\t            department: department\n607\t        )\n608\t    }\n609\t\n610\t    private func makePeople(\n611\t        id: Int,\n612\t        name: String,\n613\t        character: String? = nil,\n614\t        department: String? = nil,\n615\t        knownFor: [People.KnownFor]? = nil,\n616\t        images: [ImageData]? = nil\n617\t    ) -> People {\n618\t        People(\n619\t            id: id,\n620\t            name: name,\n621\t            character: character,\n622\t            department: department,\n623\t            profile_path: nil,\n624\t            known_for_department: nil,\n625\t            known_for: knownFor,\n626\t            also_known_as: nil,\n627\t            birthDay: nil,\n628\t            deathDay: nil,\n629\t            place_of_birth: nil,\n630\t            biography: nil,\n631\t            popularity: nil,\n632\t            images: images\n633\t        )\n634\t    }\n635\t}\n636\t"}]},"uuid":"6aa177b3-64e2-4951-a9f5-b09ff4afe525","timestamp":"2026-05-30T02:34:29.373Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/Packages/MovieSwiftFluxCore/Tests/MovieSwiftFluxCoreTests/ReducerTests.swift","content":"import Testing\n@testable import MovieSwiftFluxCore\n\n@Suite struct ReducerTests {\n    @Test func moviesReducerSetMovieMenuListPageOneReplacesList() {\n        var state = MoviesState()\n        state.moviesList[.popular] = [999]\n\n        let response = paginated([makeMovie(id: 1), makeMovie(id: 2)])\n        let action = MoviesActions.SetMovieMenuList(page: 1, list: .popular, response: response)\n\n        let reduced = moviesStateReducer(state: state, action: action)\n\n        #expect((reduced.moviesList[.popular] ?? []) == [1, 2])\n        #expect(reduced.movies[1]?.id == 1)\n        #expect(reduced.movies[2]?.id == 2)\n    }\n\n    @Test func moviesReducerSetMovieMenuListPageTwoAppendsList() {\n        var state = MoviesState()\n        state.moviesList[.trending] = [1]\n\n        let response = paginated([makeMovie(id: 2), makeMovie(id: 3)])\n        let action = MoviesActions.SetMovieMenuList(page: 2, list: .trending, response: response)\n\n        let reduced = moviesStateReducer(state: state, action: action)\n\n        #expect((reduced.moviesList[.trending] ?? []) == [1, 2, 3])\n    }\n\n    @Test func moviesReducerAddToWishlistMovesMovieAndAddsMetaTimestamp() {\n        var state = MoviesState()\n        state.seenlist.insert(42)\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddToWishlist(movie: 42))\n\n        #expect(reduced.wishlist.contains(42))\n        #expect(!(reduced.seenlist.contains(42)))\n        #expect(reduced.moviesUserMeta[42]?.addedToList != nil)\n    }\n\n    @Test func moviesReducerSetRandomDiscoverPrependsWhenBelowLimit() {\n        var state = MoviesState()\n        state.discover = [100, 101]\n        let filter = DiscoverFilter(year: 1990, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: 12, region: \"US\")\n        let response = paginated([makeMovie(id: 1), makeMovie(id: 2)])\n\n        let reduced = moviesStateReducer(\n            state: state,\n            action: MoviesActions.SetRandomDiscover(filter: filter, response: response)\n        )\n\n        #expect(reduced.discover == [1, 2, 100, 101])\n        #expect(reduced.movies[1]?.id == 1)\n        #expect(reduced.movies[2]?.id == 2)\n        #expect(reduced.discoverFilter?.year == filter.year)\n        #expect(reduced.discoverFilter?.sort == filter.sort)\n        #expect(reduced.discoverFilter?.genre == filter.genre)\n        #expect(reduced.discoverFilter?.region == filter.region)\n    }\n\n    @Test func moviesReducerSetRandomDiscoverDoesNotPrependWhenAtLimit() {\n        var state = MoviesState()\n        state.discover = Array(1...10)\n        let filter = DiscoverFilter(year: 1990, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n        let response = paginated([makeMovie(id: 99)])\n\n        let reduced = moviesStateReducer(\n            state: state,\n            action: MoviesActions.SetRandomDiscover(filter: filter, response: response)\n        )\n\n        #expect(reduced.discover == Array(1...10))\n        #expect(reduced.movies[99]?.id == 99)\n        #expect(reduced.discoverFilter?.year == 1990)\n    }\n\n    @Test func moviesReducerSetActiveDiscoverFilterUpdatesFilterImmediately() {\n        var state = MoviesState()\n        state.discoverFilter = nil\n        let filter = DiscoverFilter(year: 2001, startYear: 1990, endYear: 1999, sort: \"popularity.desc\", genre: 28, region: \"US\")\n\n        let reduced = moviesStateReducer(\n            state: state,\n            action: MoviesActions.SetActiveDiscoverFilter(filter: filter)\n        )\n\n        #expect(reduced.discoverFilter?.startYear == 1990)\n        #expect(reduced.discoverFilter?.endYear == 1999)\n        #expect(reduced.discoverFilter?.genre == 28)\n        #expect(reduced.discoverFilter?.region == \"US\")\n    }\n\n    @Test func moviesReducerSetGenresInsertsRandomGenreFirst() {\n        let genres = [Genre(id: 7, name: \"Drama\"), Genre(id: 8, name: \"Comedy\")]\n\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetGenres(genres: genres))\n\n        #expect(reduced.genres.first?.id == -1)\n        #expect(reduced.genres.first?.name == \"Random\")\n        #expect(reduced.genres.dropFirst().map(\\.id) == [7, 8])\n    }\n\n    @Test func moviesReducerAddMoviesToCustomListMergesIntoExistingList() {\n        let existing = CustomList(id: 9, name: \"Favorites\", cover: nil, movies: [1, 2])\n        var state = MoviesState()\n        state.customLists[9] = existing\n\n        let reduced = moviesStateReducer(\n            state: state,\n            action: MoviesActions.AddMoviesToCustomList(list: 9, movies: [2, 3, 4])\n        )\n\n        #expect(reduced.customLists[9]?.movies == Set([1, 2, 3, 4]))\n    }\n\n    @Test func moviesReducerEditCustomListUpdatesOnlyProvidedFields() {\n        let existing = CustomList(id: 4, name: \"Weekend\", cover: 7, movies: [7, 8])\n        var state = MoviesState()\n        state.customLists[4] = existing\n\n        let renamed = moviesStateReducer(\n            state: state,\n            action: MoviesActions.EditCustomList(list: 4, title: \"Weeknight\", cover: nil)\n        )\n        #expect(renamed.customLists[4]?.name == \"Weeknight\")\n        #expect(renamed.customLists[4]?.cover == 7)\n\n        let recoved = moviesStateReducer(\n            state: renamed,\n            action: MoviesActions.EditCustomList(list: 4, title: nil, cover: 11)\n        )\n        #expect(recoved.customLists[4]?.name == \"Weeknight\")\n        #expect(recoved.customLists[4]?.cover == 11)\n    }\n\n    @Test func peopleReducerSetDetailPreservesExistingMetadataFields() {\n        let knownFor = [People.KnownFor(id: 90, original_title: \"Old\", poster_path: \"/old.jpg\")]\n        let images = [ImageData(aspect_ratio: 1.0, file_path: \"/img.jpg\", height: 10, width: 10)]\n\n        var state = PeoplesState()\n        state.peoples[5] = makePeople(id: 5, name: \"Old Name\", character: \"Old Char\", department: \"Directing\", knownFor: knownFor, images: images)\n\n        let incoming = makePeople(id: 5, name: \"New Name\", character: nil, department: nil, knownFor: nil, images: nil)\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetDetail(person: incoming))\n\n        #expect(reduced.peoples[5]?.name == \"New Name\")\n        // SetDetail only preserves known_for and images from the existing record;\n        // character and department come from the incoming person as-is.\n        #expect(reduced.peoples[5]?.character == nil)\n        #expect(reduced.peoples[5]?.department == nil)\n        #expect(reduced.peoples[5]?.known_for?.first?.id == 90)\n        #expect(reduced.peoples[5]?.images?.first?.file_path == \"/img.jpg\")\n    }\n\n    @Test func peopleReducerSetMovieCastsMergesPeopleAndIndexesMovie() {\n        let cast = makePeople(id: 1, name: \"Cast Member\")\n        let crew = makePeople(id: 2, name: \"Crew Member\")\n        let response = CastResponse(id: 100, cast: [cast], crew: [crew])\n\n        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetMovieCasts(movie: 99, response: response))\n\n        #expect(reduced.peoples[1]?.name == \"Cast Member\")\n        #expect(reduced.peoples[2]?.name == \"Crew Member\")\n        #expect(reduced.peoplesMovies[99] == Set([1, 2]))\n    }\n\n    @Test func peopleReducerSetPeopleCreditsStoresCharacterAndDepartmentMaps() {\n        let castMovie = makeMovie(id: 10, character: \"Hero\", department: nil)\n        let castMovieWithoutCharacter = makeMovie(id: 11, character: nil, department: nil)\n        let crewMovie = makeMovie(id: 20, character: nil, department: \"Directing\")\n        let crewMovieWithoutDepartment = makeMovie(id: 21, character: nil, department: nil)\n\n        let response = PeopleActions.PeopleCreditsResponse(\n            cast: [castMovie, castMovieWithoutCharacter],\n            crew: [crewMovie, crewMovieWithoutDepartment]\n        )\n\n        let reduced = peoplesStateReducer(\n            state: PeoplesState(),\n            action: PeopleActions.SetPeopleCredits(people: 7, response: response)\n        )\n\n        #expect(reduced.casts[7]?[10] == \"Hero\")\n        #expect(reduced.casts[7]?[11] == nil)\n        #expect(reduced.crews[7]?[20] == \"Directing\")\n        #expect(reduced.crews[7]?[21] == nil)\n    }\n\n    @Test func appReducerRoutesMovieActionToMoviesState() {\n        var state = AppState()\n        state.moviesState.seenlist.insert(5)\n\n        let reduced = appStateReducer(state: state, action: MoviesActions.AddToWishlist(movie: 5))\n\n        #expect(reduced.moviesState.wishlist.contains(5))\n        #expect(!(reduced.moviesState.seenlist.contains(5)))\n    }\n\n    @Test func appReducerRoutesPeopleActionToPeoplesState() {\n        let reduced = appStateReducer(state: AppState(), action: PeopleActions.AddToFanClub(people: 55))\n\n        #expect(reduced.peoplesState.fanClub.contains(55))\n    }\n\n    // MARK: - MoviesReducer: SetDetail\n\n    @Test func moviesReducerSetDetailStoresMovieAndMarksDetailed() {\n        let movie = makeMovie(id: 42)\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetDetail(movie: 42, response: movie))\n\n        #expect(reduced.movies[42]?.id == 42)\n        #expect(reduced.detailed.contains(42))\n    }\n\n    // MARK: - MoviesReducer: SetRecommended / SetSimilar\n\n    @Test func moviesReducerSetRecommendedMergesMoviesAndMarksLoaded() {\n        let response = paginated([makeMovie(id: 10), makeMovie(id: 11)])\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetRecommended(movie: 5, response: response))\n\n        #expect(reduced.recommended[5] == [10, 11])\n        #expect(reduced.recommendedLoaded.contains(5))\n        #expect(reduced.movies[10] != nil)\n        #expect(reduced.movies[11] != nil)\n    }\n\n    @Test func moviesReducerSetSimilarMergesMoviesAndMarksLoaded() {\n        let response = paginated([makeMovie(id: 20)])\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetSimilar(movie: 6, response: response))\n\n        #expect(reduced.similar[6] == [20])\n        #expect(reduced.similarLoaded.contains(6))\n    }\n\n    // MARK: - MoviesReducer: SetVideos\n\n    @Test func moviesReducerSetVideosStoresResultsAndMarksLoaded() {\n        let video = Video(id: \"v1\", name: \"Trailer\", site: \"YouTube\", key: \"abc\", type: \"Trailer\")\n        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [video])\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetVideos(movie: 7, response: response))\n\n        #expect(reduced.videos[7]?.first?.key == \"abc\")\n        #expect(reduced.videosLoaded.contains(7))\n    }\n\n    // MARK: - MoviesReducer: SetSearch\n\n    @Test func moviesReducerSetSearchPageOneReplacesList() {\n        var state = MoviesState()\n        state.search[\"old\"] = [999]\n\n        let response = paginated([makeMovie(id: 1)])\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetSearch(query: \"old\", page: 1, response: response))\n\n        #expect(reduced.search[\"old\"] == [1])\n    }\n\n    @Test func moviesReducerSetSearchPageTwoAppendsList() {\n        var state = MoviesState()\n        state.search[\"q\"] = [1]\n\n        let response = paginated([makeMovie(id: 2)])\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetSearch(query: \"q\", page: 2, response: response))\n\n        #expect(reduced.search[\"q\"] == [1, 2])\n    }\n\n    // MARK: - MoviesReducer: SetSearchKeyword\n\n    @Test func moviesReducerSetSearchKeywordStoresKeywords() {\n        let keywords = [Keyword(id: 1, name: \"neo-noir\"), Keyword(id: 2, name: \"heist\")]\n        let response = PaginatedResponse(page: 1, total_results: 2, total_pages: 1, results: keywords)\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetSearchKeyword(query: \"noir\", response: response))\n\n        #expect(reduced.searchKeywords[\"noir\"]?.count == 2)\n        #expect(reduced.searchKeywords[\"noir\"]?.first?.name == \"neo-noir\")\n    }\n\n    // MARK: - MoviesReducer: Wishlist / Seenlist\n\n    @Test func moviesReducerRemoveFromWishlistRemovesMovie() {\n        var state = MoviesState()\n        state.wishlist.insert(42)\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveFromWishlist(movie: 42))\n\n        #expect(!(reduced.wishlist.contains(42)))\n    }\n\n    @Test func moviesReducerAddToSeenListMovesFromWishlistAndAddsTimestamp() {\n        var state = MoviesState()\n        state.wishlist.insert(42)\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddToSeenList(movie: 42))\n\n        #expect(reduced.seenlist.contains(42))\n        #expect(!(reduced.wishlist.contains(42)))\n        #expect(reduced.moviesUserMeta[42]?.addedToList != nil)\n    }\n\n    @Test func moviesReducerRemoveFromSeenListRemovesMovie() {\n        var state = MoviesState()\n        state.seenlist.insert(42)\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveFromSeenList(movie: 42))\n\n        #expect(!(reduced.seenlist.contains(42)))\n    }\n\n    // MARK: - MoviesReducer: CustomList operations\n\n    @Test func moviesReducerAddMovieToCustomListInsertsMovie() {\n        var state = MoviesState()\n        state.customLists[1] = CustomList(id: 1, name: \"Favorites\", cover: nil, movies: [10])\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddMovieToCustomList(list: 1, movie: 20))\n\n        #expect(reduced.customLists[1]?.movies.contains(20) == true)\n        #expect(reduced.customLists[1]?.movies.contains(10) == true)\n    }\n\n    @Test func moviesReducerRemoveMovieFromCustomListRemovesMovie() {\n        var state = MoviesState()\n        state.customLists[1] = CustomList(id: 1, name: \"Favorites\", cover: nil, movies: [10, 20])\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveMovieFromCustomList(list: 1, movie: 10))\n\n        #expect(!(reduced.customLists[1]?.movies.contains(10) == true))\n        #expect(reduced.customLists[1]?.movies.contains(20) == true)\n    }\n\n    @Test func moviesReducerAddCustomListStoresList() {\n        let list = CustomList(id: 5, name: \"Watch Later\", cover: nil, movies: [])\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.AddCustomList(list: list))\n\n        #expect(reduced.customLists[5]?.name == \"Watch Later\")\n    }\n\n    @Test func moviesReducerRemoveCustomListNilifiesEntry() {\n        var state = MoviesState()\n        state.customLists[5] = CustomList(id: 5, name: \"Old\", cover: nil, movies: [])\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.RemoveCustomList(list: 5))\n\n        #expect(reduced.customLists[5] == nil)\n    }\n\n    // MARK: - MoviesReducer: Genre / Crew / Keyword movies\n\n    @Test func moviesReducerSetMovieForGenrePageOneReplacesList() {\n        var state = MoviesState()\n        state.withGenre[28] = [999]\n\n        let genre = Genre(id: 28, name: \"Action\")\n        let response = paginated([makeMovie(id: 1)])\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieForGenre(genre: genre, page: 1, response: response))\n\n        #expect(reduced.withGenre[28] == [1])\n    }\n\n    @Test func moviesReducerSetMovieForGenrePageTwoAppendsList() {\n        var state = MoviesState()\n        state.withGenre[28] = [1]\n\n        let genre = Genre(id: 28, name: \"Action\")\n        let response = paginated([makeMovie(id: 2)])\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieForGenre(genre: genre, page: 2, response: response))\n\n        #expect(reduced.withGenre[28] == [1, 2])\n    }\n\n    @Test func moviesReducerSetMovieWithCrewStoresResults() {\n        let response = paginated([makeMovie(id: 10)])\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetMovieWithCrew(crew: 15, response: response))\n\n        #expect(reduced.withCrew[15] == [10])\n    }\n\n    @Test func moviesReducerSetMovieWithKeywordPageOneReplacesList() {\n        var state = MoviesState()\n        state.withKeywords[50] = [999]\n\n        let response = paginated([makeMovie(id: 1)])\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieWithKeyword(keyword: 50, page: 1, response: response))\n\n        #expect(reduced.withKeywords[50] == [1])\n    }\n\n    @Test func moviesReducerSetMovieWithKeywordPageTwoAppendsList() {\n        var state = MoviesState()\n        state.withKeywords[50] = [1]\n\n        let response = paginated([makeMovie(id: 2)])\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SetMovieWithKeyword(keyword: 50, page: 2, response: response))\n\n        #expect(reduced.withKeywords[50] == [1, 2])\n    }\n\n    // MARK: - MoviesReducer: Reviews\n\n    @Test func moviesReducerSetMovieReviewsStoresResultsAndMarksLoaded() {\n        let review = Review(id: \"r1\", author: \"Critic\", content: \"Great\")\n        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [review])\n        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetMovieReviews(movie: 8, response: response))\n\n        #expect(reduced.reviews[8]?.first?.author == \"Critic\")\n        #expect(reduced.reviewsLoaded.contains(8))\n    }\n\n    // MARK: - MoviesReducer: Discover operations\n\n    @Test func moviesReducerPopRandomDiscoverRemovesLastElement() {\n        var state = MoviesState()\n        state.discover = [1, 2, 3]\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.PopRandromDiscover())\n\n        #expect(reduced.discover == [1, 2])\n    }\n\n    @Test func moviesReducerPushRandomDiscoverAppendsMovie() {\n        var state = MoviesState()\n        state.discover = [1, 2]\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.PushRandomDiscover(movie: 3))\n\n        #expect(reduced.discover == [1, 2, 3])\n    }\n\n    @Test func moviesReducerResetRandomDiscoverClearsFilterAndList() {\n        var state = MoviesState()\n        state.discover = [1, 2, 3]\n        state.discoverFilter = DiscoverFilter(year: 2000, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.ResetRandomDiscover())\n\n        #expect(reduced.discover.isEmpty)\n        #expect(reduced.discoverFilter == nil)\n    }\n\n    @Test func moviesReducerSaveDiscoverFilterAppendsFilter() {\n        var state = MoviesState()\n        let filter1 = DiscoverFilter(year: 2000, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n        state.savedDiscoverFilters = [filter1]\n\n        let filter2 = DiscoverFilter(year: 2010, startYear: nil, endYear: nil, sort: \"vote_average.desc\", genre: 28, region: \"US\")\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.SaveDiscoverFilter(filter: filter2))\n\n        #expect(reduced.savedDiscoverFilters.count == 2)\n        #expect(reduced.savedDiscoverFilters.last?.year == 2010)\n    }\n\n    @Test func moviesReducerClearSavedDiscoverFiltersEmptiesArray() {\n        var state = MoviesState()\n        let filter = DiscoverFilter(year: 2000, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n        state.savedDiscoverFilters = [filter]\n\n        let reduced = moviesStateReducer(state: state, action: MoviesActions.ClearSavedDiscoverFilters())\n\n        #expect(reduced.savedDiscoverFilters.isEmpty)\n    }\n\n    // MARK: - MoviesReducer: Cross-reducer (PeopleCredits merges movies)\n\n    @Test func moviesReducerPeopleCreditsAlsoMergesMoviesIntoMoviesState() {\n        let castMovie = makeMovie(id: 10)\n        let crewMovie = makeMovie(id: 20)\n        let response = PeopleActions.PeopleCreditsResponse(cast: [castMovie], crew: [crewMovie])\n\n        let reduced = moviesStateReducer(state: MoviesState(), action: PeopleActions.SetPeopleCredits(people: 7, response: response))\n\n        #expect(reduced.movies[10] != nil)\n        #expect(reduced.movies[20] != nil)\n    }\n\n    // MARK: - PeopleReducer: Search\n\n    @Test func peopleReducerSetSearchPageOneReplacesList() {\n        var state = PeoplesState()\n        state.search[\"old\"] = [999]\n\n        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 1, name: \"A\")])\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetSearch(query: \"old\", page: 1, response: response))\n\n        #expect(reduced.search[\"old\"] == [1])\n    }\n\n    @Test func peopleReducerSetSearchPageTwoAppendsList() {\n        var state = PeoplesState()\n        state.search[\"q\"] = [1]\n\n        let response = PaginatedResponse(page: 2, total_results: 2, total_pages: 2, results: [makePeople(id: 2, name: \"B\")])\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetSearch(query: \"q\", page: 2, response: response))\n\n        #expect(reduced.search[\"q\"] == [1, 2])\n    }\n\n    // MARK: - PeopleReducer: Popular\n\n    @Test func peopleReducerSetPopularPageOneReplacesList() {\n        var state = PeoplesState()\n        state.popular = [999]\n        state.popularLoading = true\n\n        let response = PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 1, name: \"A\")])\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetPopular(page: 1, response: response))\n\n        #expect(reduced.popular == [1])\n        #expect(!(reduced.popularLoading))\n        #expect(reduced.popularInitialLoadCompleted)\n    }\n\n    @Test func peopleReducerSetPopularPageTwoAppendsUnique() {\n        var state = PeoplesState()\n        state.popular = [1, 2]\n\n        let response = PaginatedResponse(page: 2, total_results: 3, total_pages: 2, results: [makePeople(id: 2, name: \"B\"), makePeople(id: 3, name: \"C\")])\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetPopular(page: 2, response: response))\n\n        #expect(reduced.popular == [1, 2, 3])\n    }\n\n    // MARK: - PeopleReducer: PopularRequestStarted / Failed\n\n    @Test func peopleReducerPopularRequestStartedSetsLoadingState() {\n        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.PopularRequestStarted(page: 1))\n\n        #expect(reduced.popularLoading)\n        #expect(!(reduced.popularLoadFailed))\n        #expect(!(reduced.popularInitialLoadCompleted))\n    }\n\n    @Test func peopleReducerPopularRequestFailedSetsFailedState() {\n        var state = PeoplesState()\n        state.popularLoading = true\n\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.PopularRequestFailed(page: 1))\n\n        #expect(!(reduced.popularLoading))\n        #expect(reduced.popularLoadFailed)\n        #expect(reduced.popularInitialLoadCompleted)\n    }\n\n    // MARK: - PeopleReducer: FanClub\n\n    @Test func peopleReducerAddToFanClubInsertsPeopleId() {\n        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.AddToFanClub(people: 55))\n\n        #expect(reduced.fanClub.contains(55))\n    }\n\n    @Test func peopleReducerRemoveFromFanClubRemovesPeopleId() {\n        var state = PeoplesState()\n        state.fanClub.insert(55)\n\n        let reduced = peoplesStateReducer(state: state, action: PeopleActions.RemoveFromFanClub(people: 55))\n\n        #expect(!(reduced.fanClub.contains(55)))\n    }\n\n    // MARK: - PeopleReducer: SetImages\n\n    @Test func peopleReducerSetImagesStoresImagesAndMarksLoaded() {\n        let images = [ImageData(aspect_ratio: 0.67, file_path: \"/img.jpg\", height: 300, width: 200)]\n        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetImages(people: 7, images: images))\n\n        #expect(reduced.peoples[7]?.images?.first?.file_path == \"/img.jpg\")\n        #expect(reduced.imagesLoaded.contains(7))\n    }\n\n    // MARK: - PeopleReducer: SetDetail new person\n\n    @Test func peopleReducerSetDetailNewPersonStoresDirectly() {\n        let person = makePeople(id: 10, name: \"New Person\")\n        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetDetail(person: person))\n\n        #expect(reduced.peoples[10]?.name == \"New Person\")\n        #expect(reduced.detailed.contains(10))\n    }\n\n    private func paginated<T: Codable>(_ values: [T]) -> PaginatedResponse<T> {\n        PaginatedResponse(page: 1, total_results: values.count, total_pages: 1, results: values)\n    }\n\n    private func makeMovie(id: Int, character: String? = nil, department: String? = nil) -> Movie {\n        Movie(\n            id: id,\n            original_title: \"Original \\(id)\",\n            title: \"Title \\(id)\",\n            overview: \"Overview \\(id)\",\n            poster_path: nil,\n            backdrop_path: nil,\n            popularity: 1.0,\n            vote_average: 2.0,\n            vote_count: 3,\n            release_date: \"2020-01-01\",\n            genres: nil,\n            runtime: nil,\n            status: nil,\n            video: false,\n            keywords: nil,\n            images: nil,\n            production_countries: nil,\n            character: character,\n            department: department\n        )\n    }\n\n    private func makePeople(\n        id: Int,\n        name: String,\n        character: String? = nil,\n        department: String? = nil,\n        knownFor: [People.KnownFor]? = nil,\n        images: [ImageData]? = nil\n    ) -> People {\n        People(\n            id: id,\n            name: name,\n            character: character,\n            department: department,\n            profile_path: nil,\n            known_for_department: nil,\n            known_for: knownFor,\n            also_known_as: nil,\n            birthDay: nil,\n            deathDay: nil,\n            place_of_birth: nil,\n            biography: nil,\n            popularity: nil,\n            images: images\n        )\n    }\n}\n","numLines":636,"startLine":1,"totalLines":636}},"sourceToolAssistantUUID":"2947a011-f3f9-4961-a52e-c205103d32ed","userType":"external","entrypoint":"claude-desktop","cwd":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift","sessionId":"2cae28a4-28e8-4bfa-9225-7682543f3664","version":"2.1.149","gitBranch":"modernize/parameterize-reducer-tests","slug":"snuggly-shimmying-pebble"}
