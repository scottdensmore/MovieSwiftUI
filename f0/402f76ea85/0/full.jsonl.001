{"parentUuid":"0aa527e4-d23a-4e4b-a3f7-c25f56f9233c","isSidechain":false,"message":{"model":"claude-opus-4-7","id":"msg_019XoE1mGT3KmKRW6apY82Po","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018PdKuMREDYJcmwy5ceTjyy","name":"Read","input":{"file_path":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/MovieSwiftTests/PeopleActionsTests.swift"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4723,"cache_read_input_tokens":162480,"output_tokens":267,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":4723,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":267,"cache_read_input_tokens":162480,"cache_creation_input_tokens":4723,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4723},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CbXzKc9qkMv6DsVAugMH3","attributionMcpServer":"ccd_session","attributionMcpTool":"mark_chapter","type":"assistant","uuid":"bac42407-eea8-468e-a870-7e6fea7ed66f","timestamp":"2026-05-30T02:47:11.707Z","userType":"external","entrypoint":"claude-desktop","cwd":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/Packages/MovieSwiftFluxCore","sessionId":"2cae28a4-28e8-4bfa-9225-7682543f3664","version":"2.1.149","gitBranch":"modernize/parameterize-people-actions-tests","slug":"snuggly-shimmying-pebble"}
{"parentUuid":"bac42407-eea8-468e-a870-7e6fea7ed66f","isSidechain":false,"promptId":"af759ad8-76cc-4b58-b2d3-322690ab2306","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018PdKuMREDYJcmwy5ceTjyy","type":"tool_result","content":"1\timport Testing\n2\timport Foundation\n3\timport Backend\n4\timport SwiftUIFlux\n5\timport MovieSwiftFluxCore\n6\t#if os(macOS)\n7\t@testable import Film_O_Matic\n8\t#else\n9\t@testable import MovieSwift\n10\t#endif\n11\t\n12\t// `.serialized` + final class: every test swaps the shared global\n13\t// `APIService.shared`, so the suite can't run in parallel, and init/deinit\n14\t// snapshot & restore that value as per-test setup/teardown.\n15\t@Suite(.serialized)\n16\tfinal class PeopleActionsTests {\n17\t    private final class StubAPIKeyProvider: APIKeyProviding {\n18\t        private let value: String?\n19\t\n20\t        init(_ value: String?) {\n21\t            self.value = value\n22\t        }\n23\t\n24\t        func apiKey() -> String? {\n25\t            value\n26\t        }\n27\t    }\n28\t\n29\t    private final class MockNetworkSession: NetworkSession, @unchecked Sendable {\n30\t        var lastRequest: URLRequest?\n31\t        var nextData: Data?\n32\t        var nextResponse: URLResponse?\n33\t        var nextError: Error?\n34\t\n35\t        func data(for request: URLRequest) async throws -> (Data, URLResponse) {\n36\t            lastRequest = request\n37\t            if let nextError { throw nextError }\n38\t            let response = nextResponse\n39\t                ?? HTTPURLResponse(url: request.url!, statusCode: 200,\n40\t                                   httpVersion: \"HTTP/1.1\", headerFields: nil)!\n41\t            return (nextData ?? Data(), response)\n42\t        }\n43\t    }\n44\t\n45\t    private enum StubError: Error {\n46\t        case failed\n47\t    }\n48\t\n49\t    private let originalAPIService: APIService\n50\t\n51\t    init() {\n52\t        originalAPIService = APIService.shared\n53\t    }\n54\t\n55\t    deinit {\n56\t        APIService.shared = originalAPIService\n57\t    }\n58\t\n59\t    // MARK: - Dispatch capture helpers\n60\t    //\n61\t    // The AsyncAction `execute(state:dispatch:)` flow funnels through\n62\t    // `APIService.GET`'s completion handler, which fires on a background\n63\t    // callback queue. These bridge that to async/await: a lock guards the\n64\t    // cross-thread mutation, and a class box carries the non-Sendable\n65\t    // `[Action]` across the continuation.\n66\t\n67\t    private final class DispatchCollector: @unchecked Sendable {\n68\t        let lock = NSLock()\n69\t        var dispatched: [Action] = []\n70\t        var didResume = false\n71\t    }\n72\t\n73\t    private struct ActionsBox: @unchecked Sendable {\n74\t        let actions: [Action]\n75\t    }\n76\t\n77\t    /// Collects dispatched actions, returning once `trigger` matches one of\n78\t    /// them (or after a 2s safety timeout).\n79\t    private func collectDispatches(\n80\t        until trigger: @escaping (Action) -> Bool,\n81\t        when execute: (@escaping DispatchFunction) -> Void\n82\t    ) async -> [Action] {\n83\t        let collector = DispatchCollector()\n84\t        return await withCheckedContinuation { (continuation: CheckedContinuation<ActionsBox, Never>) in\n85\t            execute { action in\n86\t                collector.lock.lock()\n87\t                collector.dispatched.append(action)\n88\t                let shouldResume = trigger(action) && !collector.didResume\n89\t                if shouldResume { collector.didResume = true }\n90\t                let snapshot = collector.dispatched\n91\t                collector.lock.unlock()\n92\t                if shouldResume { continuation.resume(returning: ActionsBox(actions: snapshot)) }\n93\t            }\n94\t            DispatchQueue.global().asyncAfter(deadline: .now() + 2.0) {\n95\t                collector.lock.lock()\n96\t                let shouldResume = !collector.didResume\n97\t                if shouldResume { collector.didResume = true }\n98\t                let snapshot = collector.dispatched\n99\t                collector.lock.unlock()\n100\t                if shouldResume { continuation.resume(returning: ActionsBox(actions: snapshot)) }\n101\t            }\n102\t        }.actions\n103\t    }\n104\t\n105\t    /// Collects everything dispatched within `seconds` and returns it — the\n106\t    /// async equivalent of an inverted XCTestExpectation (used to assert a\n107\t    /// particular data action is NOT dispatched on a failure path).\n108\t    private func collectDispatches(\n109\t        forSeconds seconds: Double,\n110\t        when execute: (@escaping DispatchFunction) -> Void\n111\t    ) async -> [Action] {\n112\t        let collector = DispatchCollector()\n113\t        return await withCheckedContinuation { (continuation: CheckedContinuation<ActionsBox, Never>) in\n114\t            execute { action in\n115\t                collector.lock.lock()\n116\t                collector.dispatched.append(action)\n117\t                collector.lock.unlock()\n118\t            }\n119\t            DispatchQueue.global().asyncAfter(deadline: .now() + seconds) {\n120\t                collector.lock.lock()\n121\t                let snapshot = collector.dispatched\n122\t                collector.lock.unlock()\n123\t                continuation.resume(returning: ActionsBox(actions: snapshot))\n124\t            }\n125\t        }.actions\n126\t    }\n127\t\n128\t    // MARK: - FetchDetail\n129\t\n130\t    @Test func fetchDetailDispatchesSetDetailOnSuccess() async throws {\n131\t        let session = MockNetworkSession()\n132\t        session.nextData = try JSONEncoder().encode(makePeople(id: 5, name: \"Alice\"))\n133\t\n134\t        APIService.shared = APIService(\n135\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n136\t            session: session,\n137\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchDetail\")\n138\t        )\n139\t\n140\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetDetail }) { dispatch in\n141\t            PeopleActions.FetchDetail(people: 5).execute(state: nil, dispatch: dispatch)\n142\t        }\n143\t\n144\t        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetDetail }.first\n145\t        #expect(dispatchedAction?.person.id == 5)\n146\t        #expect(dispatchedAction?.person.name == \"Alice\")\n147\t        #expect(session.lastRequest != nil, \"expected the request to be issued\")\n148\t\n149\t        let requestURL = try #require(session.lastRequest?.url)\n150\t        #expect(requestURL.path.contains(\"/person/5\"))\n151\t    }\n152\t\n153\t    @Test func fetchDetailDoesNotDispatchOnFailure() async {\n154\t        let session = MockNetworkSession()\n155\t        session.nextData = nil\n156\t        session.nextError = StubError.failed\n157\t\n158\t        APIService.shared = APIService(\n159\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n160\t            session: session,\n161\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchDetailFailure\")\n162\t        )\n163\t\n164\t        // FetchDetail also dispatches SetLoadingState(.loading) synchronously\n165\t        // and SetLoadingState(.failed(...)) on failure. This test specifically\n166\t        // checks the data action is NOT dispatched — ignoring those.\n167\t        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n168\t            PeopleActions.FetchDetail(people: 5).execute(state: nil, dispatch: dispatch)\n169\t        }\n170\t\n171\t        #expect(!dispatched.contains { $0 is PeopleActions.SetDetail })\n172\t        #expect(session.lastRequest != nil, \"expected the request to be issued\")\n173\t    }\n174\t\n175\t    // MARK: - FetchImages\n176\t\n177\t    @Test func fetchImagesDispatchesSetImagesOnSuccess() async throws {\n178\t        let session = MockNetworkSession()\n179\t        let payload = PeopleActions.ImagesResponse(\n180\t            id: 7,\n181\t            profiles: [ImageData(aspect_ratio: 0.67, file_path: \"/img.jpg\", height: 300, width: 200)]\n182\t        )\n183\t        session.nextData = try JSONEncoder().encode(payload)\n184\t\n185\t        APIService.shared = APIService(\n186\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n187\t            session: session,\n188\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchImages\")\n189\t        )\n190\t\n191\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetImages }) { dispatch in\n192\t            PeopleActions.FetchImages(people: 7).execute(state: nil, dispatch: dispatch)\n193\t        }\n194\t\n195\t        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetImages }.first\n196\t        #expect(dispatchedAction?.people == 7)\n197\t        #expect(dispatchedAction?.images.count == 1)\n198\t        #expect(dispatchedAction?.images.first?.file_path == \"/img.jpg\")\n199\t    }\n200\t\n201\t    @Test func fetchImagesDoesNotDispatchOnFailure() async {\n202\t        let session = MockNetworkSession()\n203\t        session.nextError = StubError.failed\n204\t\n205\t        APIService.shared = APIService(\n206\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n207\t            session: session,\n208\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchImagesFailure\")\n209\t        )\n210\t\n211\t        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n212\t            PeopleActions.FetchImages(people: 7).execute(state: nil, dispatch: dispatch)\n213\t        }\n214\t\n215\t        #expect(!dispatched.contains { $0 is PeopleActions.SetImages })\n216\t    }\n217\t\n218\t    // MARK: - FetchPeopleCredits\n219\t\n220\t    @Test func fetchPeopleCreditsDispatchesSetPeopleCreditsOnSuccess() async throws {\n221\t        let session = MockNetworkSession()\n222\t        let payload = PeopleActions.PeopleCreditsResponse(\n223\t            cast: [makeMovie(id: 10, character: \"Hero\")],\n224\t            crew: [makeMovie(id: 20, department: \"Directing\")]\n225\t        )\n226\t        session.nextData = try JSONEncoder().encode(payload)\n227\t\n228\t        APIService.shared = APIService(\n229\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n230\t            session: session,\n231\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchCredits\")\n232\t        )\n233\t\n234\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetPeopleCredits }) { dispatch in\n235\t            PeopleActions.FetchPeopleCredits(people: 3).execute(state: nil, dispatch: dispatch)\n236\t        }\n237\t\n238\t        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetPeopleCredits }.first\n239\t        #expect(dispatchedAction?.people == 3)\n240\t        #expect(dispatchedAction?.response.cast?.first?.id == 10)\n241\t        #expect(dispatchedAction?.response.crew?.first?.id == 20)\n242\t    }\n243\t\n244\t    @Test func fetchPeopleCreditsDoesNotDispatchOnFailure() async {\n245\t        let session = MockNetworkSession()\n246\t        session.nextError = StubError.failed\n247\t\n248\t        APIService.shared = APIService(\n249\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n250\t            session: session,\n251\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchCreditsFailure\")\n252\t        )\n253\t\n254\t        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n255\t            PeopleActions.FetchPeopleCredits(people: 3).execute(state: nil, dispatch: dispatch)\n256\t        }\n257\t\n258\t        #expect(!dispatched.contains { $0 is PeopleActions.SetPeopleCredits })\n259\t    }\n260\t\n261\t    // MARK: - FetchMovieCasts\n262\t\n263\t    @Test func fetchMovieCastsDispatchesSetMovieCastsOnSuccess() async throws {\n264\t        let session = MockNetworkSession()\n265\t        let payload = CastResponse(\n266\t            id: 99,\n267\t            cast: [makePeople(id: 1, name: \"Actor\")],\n268\t            crew: [makePeople(id: 2, name: \"Director\")]\n269\t        )\n270\t        session.nextData = try JSONEncoder().encode(payload)\n271\t\n272\t        APIService.shared = APIService(\n273\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n274\t            session: session,\n275\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchMovieCasts\")\n276\t        )\n277\t\n278\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetMovieCasts }) { dispatch in\n279\t            PeopleActions.FetchMovieCasts(movie: 99).execute(state: nil, dispatch: dispatch)\n280\t        }\n281\t\n282\t        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetMovieCasts }.first\n283\t        #expect(dispatchedAction?.movie == 99)\n284\t        #expect(dispatchedAction?.response.cast.first?.name == \"Actor\")\n285\t        #expect(dispatchedAction?.response.crew.first?.name == \"Director\")\n286\t\n287\t        let requestURL = try #require(session.lastRequest?.url)\n288\t        #expect(requestURL.path.contains(\"/movie/99/credits\"))\n289\t    }\n290\t\n291\t    @Test func fetchMovieCastsDoesNotDispatchOnFailure() async {\n292\t        let session = MockNetworkSession()\n293\t        session.nextError = StubError.failed\n294\t\n295\t        APIService.shared = APIService(\n296\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n297\t            session: session,\n298\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchMovieCastsFailure\")\n299\t        )\n300\t\n301\t        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n302\t            PeopleActions.FetchMovieCasts(movie: 99).execute(state: nil, dispatch: dispatch)\n303\t        }\n304\t\n305\t        #expect(!dispatched.contains { $0 is PeopleActions.SetMovieCasts })\n306\t    }\n307\t\n308\t    // MARK: - FetchSearch\n309\t\n310\t    @Test func fetchSearchDispatchesSetSearchOnSuccess() async throws {\n311\t        let session = MockNetworkSession()\n312\t        session.nextData = try JSONEncoder().encode(\n313\t            PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 10, name: \"Bob\")])\n314\t        )\n315\t\n316\t        APIService.shared = APIService(\n317\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n318\t            session: session,\n319\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchSearch\")\n320\t        )\n321\t\n322\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetSearch }) { dispatch in\n323\t            PeopleActions.FetchSearch(query: \"bob\", page: 1).execute(state: nil, dispatch: dispatch)\n324\t        }\n325\t\n326\t        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetSearch }.first\n327\t        #expect(dispatchedAction?.query == \"bob\")\n328\t        #expect(dispatchedAction?.page == 1)\n329\t        #expect(dispatchedAction?.response.results.first?.name == \"Bob\")\n330\t    }\n331\t\n332\t    @Test func fetchSearchDoesNotDispatchOnFailure() async {\n333\t        let session = MockNetworkSession()\n334\t        session.nextError = StubError.failed\n335\t\n336\t        APIService.shared = APIService(\n337\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n338\t            session: session,\n339\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchSearchFailure\")\n340\t        )\n341\t\n342\t        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n343\t            PeopleActions.FetchSearch(query: \"bob\", page: 1).execute(state: nil, dispatch: dispatch)\n344\t        }\n345\t\n346\t        #expect(!dispatched.contains { $0 is PeopleActions.SetSearch })\n347\t    }\n348\t\n349\t    // MARK: - FetchPopular\n350\t\n351\t    @Test func fetchPopularDispatchesPopularRequestStartedThenSetPopularOnSuccess() async throws {\n352\t        let session = MockNetworkSession()\n353\t        session.nextData = try JSONEncoder().encode(\n354\t            PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 20, name: \"Star\")])\n355\t        )\n356\t\n357\t        APIService.shared = APIService(\n358\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n359\t            session: session,\n360\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchPopular\")\n361\t        )\n362\t\n363\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetPopular }) { dispatch in\n364\t            PeopleActions.FetchPopular(page: 1).execute(state: nil, dispatch: dispatch)\n365\t        }\n366\t\n367\t        #expect(dispatched.first is PeopleActions.PopularRequestStarted)\n368\t        let setPopular = dispatched.last as? PeopleActions.SetPopular\n369\t        #expect(setPopular?.page == 1)\n370\t        #expect(setPopular?.response.results.first?.name == \"Star\")\n371\t    }\n372\t\n373\t    @Test func fetchPopularDispatchesPopularRequestFailedOnFailure() async {\n374\t        let session = MockNetworkSession()\n375\t        session.nextError = StubError.failed\n376\t\n377\t        APIService.shared = APIService(\n378\t            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n379\t            session: session,\n380\t            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchPopularFailure\")\n381\t        )\n382\t\n383\t        let dispatched = await collectDispatches(until: { $0 is PeopleActions.PopularRequestFailed }) { dispatch in\n384\t            PeopleActions.FetchPopular(page: 2).execute(state: nil, dispatch: dispatch)\n385\t        }\n386\t\n387\t        // FetchPopular now also dispatches SetLoadingState transitions\n388\t        // through makeTrackedHandler in addition to its existing\n389\t        // PopularRequestStarted / PopularRequestFailed pair. The\n390\t        // existing pair remains the source of truth for paginated\n391\t        // retry — we just verify it still fires as before.\n392\t        #expect(dispatched.contains { $0 is PeopleActions.PopularRequestStarted })\n393\t        let failed = dispatched.compactMap { $0 as? PeopleActions.PopularRequestFailed }.last\n394\t        #expect(failed?.page == 2)\n395\t    }\n396\t\n397\t    // MARK: - Helpers\n398\t\n399\t    private func makePeople(id: Int, name: String) -> People {\n400\t        People(\n401\t            id: id,\n402\t            name: name,\n403\t            character: nil,\n404\t            department: nil,\n405\t            profile_path: nil,\n406\t            known_for_department: nil,\n407\t            known_for: nil,\n408\t            also_known_as: nil,\n409\t            birthDay: nil,\n410\t            deathDay: nil,\n411\t            place_of_birth: nil,\n412\t            biography: nil,\n413\t            popularity: nil,\n414\t            images: nil\n415\t        )\n416\t    }\n417\t\n418\t    private func makeMovie(id: Int, character: String? = nil, department: String? = nil) -> Movie {\n419\t        Movie(\n420\t            id: id,\n421\t            original_title: \"Original \\(id)\",\n422\t            title: \"Title \\(id)\",\n423\t            overview: \"Overview \\(id)\",\n424\t            poster_path: nil,\n425\t            backdrop_path: nil,\n426\t            popularity: 1.0,\n427\t            vote_average: 2.0,\n428\t            vote_count: 3,\n429\t            release_date: \"2020-01-01\",\n430\t            genres: nil,\n431\t            runtime: nil,\n432\t            status: nil,\n433\t            video: false,\n434\t            keywords: nil,\n435\t            images: nil,\n436\t            production_countries: nil,\n437\t            character: character,\n438\t            department: department\n439\t        )\n440\t    }\n441\t}\n442\t"}]},"uuid":"cea56543-a0ea-4e6d-9954-a10e9d84bdaa","timestamp":"2026-05-30T02:47:11.712Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/MovieSwiftTests/PeopleActionsTests.swift","content":"import Testing\nimport Foundation\nimport Backend\nimport SwiftUIFlux\nimport MovieSwiftFluxCore\n#if os(macOS)\n@testable import Film_O_Matic\n#else\n@testable import MovieSwift\n#endif\n\n// `.serialized` + final class: every test swaps the shared global\n// `APIService.shared`, so the suite can't run in parallel, and init/deinit\n// snapshot & restore that value as per-test setup/teardown.\n@Suite(.serialized)\nfinal class PeopleActionsTests {\n    private final class StubAPIKeyProvider: APIKeyProviding {\n        private let value: String?\n\n        init(_ value: String?) {\n            self.value = value\n        }\n\n        func apiKey() -> String? {\n            value\n        }\n    }\n\n    private final class MockNetworkSession: NetworkSession, @unchecked Sendable {\n        var lastRequest: URLRequest?\n        var nextData: Data?\n        var nextResponse: URLResponse?\n        var nextError: Error?\n\n        func data(for request: URLRequest) async throws -> (Data, URLResponse) {\n            lastRequest = request\n            if let nextError { throw nextError }\n            let response = nextResponse\n                ?? HTTPURLResponse(url: request.url!, statusCode: 200,\n                                   httpVersion: \"HTTP/1.1\", headerFields: nil)!\n            return (nextData ?? Data(), response)\n        }\n    }\n\n    private enum StubError: Error {\n        case failed\n    }\n\n    private let originalAPIService: APIService\n\n    init() {\n        originalAPIService = APIService.shared\n    }\n\n    deinit {\n        APIService.shared = originalAPIService\n    }\n\n    // MARK: - Dispatch capture helpers\n    //\n    // The AsyncAction `execute(state:dispatch:)` flow funnels through\n    // `APIService.GET`'s completion handler, which fires on a background\n    // callback queue. These bridge that to async/await: a lock guards the\n    // cross-thread mutation, and a class box carries the non-Sendable\n    // `[Action]` across the continuation.\n\n    private final class DispatchCollector: @unchecked Sendable {\n        let lock = NSLock()\n        var dispatched: [Action] = []\n        var didResume = false\n    }\n\n    private struct ActionsBox: @unchecked Sendable {\n        let actions: [Action]\n    }\n\n    /// Collects dispatched actions, returning once `trigger` matches one of\n    /// them (or after a 2s safety timeout).\n    private func collectDispatches(\n        until trigger: @escaping (Action) -> Bool,\n        when execute: (@escaping DispatchFunction) -> Void\n    ) async -> [Action] {\n        let collector = DispatchCollector()\n        return await withCheckedContinuation { (continuation: CheckedContinuation<ActionsBox, Never>) in\n            execute { action in\n                collector.lock.lock()\n                collector.dispatched.append(action)\n                let shouldResume = trigger(action) && !collector.didResume\n                if shouldResume { collector.didResume = true }\n                let snapshot = collector.dispatched\n                collector.lock.unlock()\n                if shouldResume { continuation.resume(returning: ActionsBox(actions: snapshot)) }\n            }\n            DispatchQueue.global().asyncAfter(deadline: .now() + 2.0) {\n                collector.lock.lock()\n                let shouldResume = !collector.didResume\n                if shouldResume { collector.didResume = true }\n                let snapshot = collector.dispatched\n                collector.lock.unlock()\n                if shouldResume { continuation.resume(returning: ActionsBox(actions: snapshot)) }\n            }\n        }.actions\n    }\n\n    /// Collects everything dispatched within `seconds` and returns it — the\n    /// async equivalent of an inverted XCTestExpectation (used to assert a\n    /// particular data action is NOT dispatched on a failure path).\n    private func collectDispatches(\n        forSeconds seconds: Double,\n        when execute: (@escaping DispatchFunction) -> Void\n    ) async -> [Action] {\n        let collector = DispatchCollector()\n        return await withCheckedContinuation { (continuation: CheckedContinuation<ActionsBox, Never>) in\n            execute { action in\n                collector.lock.lock()\n                collector.dispatched.append(action)\n                collector.lock.unlock()\n            }\n            DispatchQueue.global().asyncAfter(deadline: .now() + seconds) {\n                collector.lock.lock()\n                let snapshot = collector.dispatched\n                collector.lock.unlock()\n                continuation.resume(returning: ActionsBox(actions: snapshot))\n            }\n        }.actions\n    }\n\n    // MARK: - FetchDetail\n\n    @Test func fetchDetailDispatchesSetDetailOnSuccess() async throws {\n        let session = MockNetworkSession()\n        session.nextData = try JSONEncoder().encode(makePeople(id: 5, name: \"Alice\"))\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchDetail\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetDetail }) { dispatch in\n            PeopleActions.FetchDetail(people: 5).execute(state: nil, dispatch: dispatch)\n        }\n\n        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetDetail }.first\n        #expect(dispatchedAction?.person.id == 5)\n        #expect(dispatchedAction?.person.name == \"Alice\")\n        #expect(session.lastRequest != nil, \"expected the request to be issued\")\n\n        let requestURL = try #require(session.lastRequest?.url)\n        #expect(requestURL.path.contains(\"/person/5\"))\n    }\n\n    @Test func fetchDetailDoesNotDispatchOnFailure() async {\n        let session = MockNetworkSession()\n        session.nextData = nil\n        session.nextError = StubError.failed\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchDetailFailure\")\n        )\n\n        // FetchDetail also dispatches SetLoadingState(.loading) synchronously\n        // and SetLoadingState(.failed(...)) on failure. This test specifically\n        // checks the data action is NOT dispatched — ignoring those.\n        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n            PeopleActions.FetchDetail(people: 5).execute(state: nil, dispatch: dispatch)\n        }\n\n        #expect(!dispatched.contains { $0 is PeopleActions.SetDetail })\n        #expect(session.lastRequest != nil, \"expected the request to be issued\")\n    }\n\n    // MARK: - FetchImages\n\n    @Test func fetchImagesDispatchesSetImagesOnSuccess() async throws {\n        let session = MockNetworkSession()\n        let payload = PeopleActions.ImagesResponse(\n            id: 7,\n            profiles: [ImageData(aspect_ratio: 0.67, file_path: \"/img.jpg\", height: 300, width: 200)]\n        )\n        session.nextData = try JSONEncoder().encode(payload)\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchImages\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetImages }) { dispatch in\n            PeopleActions.FetchImages(people: 7).execute(state: nil, dispatch: dispatch)\n        }\n\n        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetImages }.first\n        #expect(dispatchedAction?.people == 7)\n        #expect(dispatchedAction?.images.count == 1)\n        #expect(dispatchedAction?.images.first?.file_path == \"/img.jpg\")\n    }\n\n    @Test func fetchImagesDoesNotDispatchOnFailure() async {\n        let session = MockNetworkSession()\n        session.nextError = StubError.failed\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchImagesFailure\")\n        )\n\n        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n            PeopleActions.FetchImages(people: 7).execute(state: nil, dispatch: dispatch)\n        }\n\n        #expect(!dispatched.contains { $0 is PeopleActions.SetImages })\n    }\n\n    // MARK: - FetchPeopleCredits\n\n    @Test func fetchPeopleCreditsDispatchesSetPeopleCreditsOnSuccess() async throws {\n        let session = MockNetworkSession()\n        let payload = PeopleActions.PeopleCreditsResponse(\n            cast: [makeMovie(id: 10, character: \"Hero\")],\n            crew: [makeMovie(id: 20, department: \"Directing\")]\n        )\n        session.nextData = try JSONEncoder().encode(payload)\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchCredits\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetPeopleCredits }) { dispatch in\n            PeopleActions.FetchPeopleCredits(people: 3).execute(state: nil, dispatch: dispatch)\n        }\n\n        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetPeopleCredits }.first\n        #expect(dispatchedAction?.people == 3)\n        #expect(dispatchedAction?.response.cast?.first?.id == 10)\n        #expect(dispatchedAction?.response.crew?.first?.id == 20)\n    }\n\n    @Test func fetchPeopleCreditsDoesNotDispatchOnFailure() async {\n        let session = MockNetworkSession()\n        session.nextError = StubError.failed\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchCreditsFailure\")\n        )\n\n        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n            PeopleActions.FetchPeopleCredits(people: 3).execute(state: nil, dispatch: dispatch)\n        }\n\n        #expect(!dispatched.contains { $0 is PeopleActions.SetPeopleCredits })\n    }\n\n    // MARK: - FetchMovieCasts\n\n    @Test func fetchMovieCastsDispatchesSetMovieCastsOnSuccess() async throws {\n        let session = MockNetworkSession()\n        let payload = CastResponse(\n            id: 99,\n            cast: [makePeople(id: 1, name: \"Actor\")],\n            crew: [makePeople(id: 2, name: \"Director\")]\n        )\n        session.nextData = try JSONEncoder().encode(payload)\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchMovieCasts\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetMovieCasts }) { dispatch in\n            PeopleActions.FetchMovieCasts(movie: 99).execute(state: nil, dispatch: dispatch)\n        }\n\n        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetMovieCasts }.first\n        #expect(dispatchedAction?.movie == 99)\n        #expect(dispatchedAction?.response.cast.first?.name == \"Actor\")\n        #expect(dispatchedAction?.response.crew.first?.name == \"Director\")\n\n        let requestURL = try #require(session.lastRequest?.url)\n        #expect(requestURL.path.contains(\"/movie/99/credits\"))\n    }\n\n    @Test func fetchMovieCastsDoesNotDispatchOnFailure() async {\n        let session = MockNetworkSession()\n        session.nextError = StubError.failed\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchMovieCastsFailure\")\n        )\n\n        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n            PeopleActions.FetchMovieCasts(movie: 99).execute(state: nil, dispatch: dispatch)\n        }\n\n        #expect(!dispatched.contains { $0 is PeopleActions.SetMovieCasts })\n    }\n\n    // MARK: - FetchSearch\n\n    @Test func fetchSearchDispatchesSetSearchOnSuccess() async throws {\n        let session = MockNetworkSession()\n        session.nextData = try JSONEncoder().encode(\n            PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 10, name: \"Bob\")])\n        )\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchSearch\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetSearch }) { dispatch in\n            PeopleActions.FetchSearch(query: \"bob\", page: 1).execute(state: nil, dispatch: dispatch)\n        }\n\n        let dispatchedAction = dispatched.compactMap { $0 as? PeopleActions.SetSearch }.first\n        #expect(dispatchedAction?.query == \"bob\")\n        #expect(dispatchedAction?.page == 1)\n        #expect(dispatchedAction?.response.results.first?.name == \"Bob\")\n    }\n\n    @Test func fetchSearchDoesNotDispatchOnFailure() async {\n        let session = MockNetworkSession()\n        session.nextError = StubError.failed\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchSearchFailure\")\n        )\n\n        let dispatched = await collectDispatches(forSeconds: 0.2) { dispatch in\n            PeopleActions.FetchSearch(query: \"bob\", page: 1).execute(state: nil, dispatch: dispatch)\n        }\n\n        #expect(!dispatched.contains { $0 is PeopleActions.SetSearch })\n    }\n\n    // MARK: - FetchPopular\n\n    @Test func fetchPopularDispatchesPopularRequestStartedThenSetPopularOnSuccess() async throws {\n        let session = MockNetworkSession()\n        session.nextData = try JSONEncoder().encode(\n            PaginatedResponse(page: 1, total_results: 1, total_pages: 1, results: [makePeople(id: 20, name: \"Star\")])\n        )\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchPopular\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.SetPopular }) { dispatch in\n            PeopleActions.FetchPopular(page: 1).execute(state: nil, dispatch: dispatch)\n        }\n\n        #expect(dispatched.first is PeopleActions.PopularRequestStarted)\n        let setPopular = dispatched.last as? PeopleActions.SetPopular\n        #expect(setPopular?.page == 1)\n        #expect(setPopular?.response.results.first?.name == \"Star\")\n    }\n\n    @Test func fetchPopularDispatchesPopularRequestFailedOnFailure() async {\n        let session = MockNetworkSession()\n        session.nextError = StubError.failed\n\n        APIService.shared = APIService(\n            apiKeyProvider: StubAPIKeyProvider(\"test-key\"),\n            session: session,\n            callbackQueue: DispatchQueue(label: \"PeopleActionsTests.fetchPopularFailure\")\n        )\n\n        let dispatched = await collectDispatches(until: { $0 is PeopleActions.PopularRequestFailed }) { dispatch in\n            PeopleActions.FetchPopular(page: 2).execute(state: nil, dispatch: dispatch)\n        }\n\n        // FetchPopular now also dispatches SetLoadingState transitions\n        // through makeTrackedHandler in addition to its existing\n        // PopularRequestStarted / PopularRequestFailed pair. The\n        // existing pair remains the source of truth for paginated\n        // retry — we just verify it still fires as before.\n        #expect(dispatched.contains { $0 is PeopleActions.PopularRequestStarted })\n        let failed = dispatched.compactMap { $0 as? PeopleActions.PopularRequestFailed }.last\n        #expect(failed?.page == 2)\n    }\n\n    // MARK: - Helpers\n\n    private func makePeople(id: Int, name: String) -> People {\n        People(\n            id: id,\n            name: name,\n            character: nil,\n            department: nil,\n            profile_path: nil,\n            known_for_department: nil,\n            known_for: nil,\n            also_known_as: nil,\n            birthDay: nil,\n            deathDay: nil,\n            place_of_birth: nil,\n            biography: nil,\n            popularity: nil,\n            images: nil\n        )\n    }\n\n    private func makeMovie(id: Int, character: String? = nil, department: String? = nil) -> Movie {\n        Movie(\n            id: id,\n            original_title: \"Original \\(id)\",\n            title: \"Title \\(id)\",\n            overview: \"Overview \\(id)\",\n            poster_path: nil,\n            backdrop_path: nil,\n            popularity: 1.0,\n            vote_average: 2.0,\n            vote_count: 3,\n            release_date: \"2020-01-01\",\n            genres: nil,\n            runtime: nil,\n            status: nil,\n            video: false,\n            keywords: nil,\n            images: nil,\n            production_countries: nil,\n            character: character,\n            department: department\n        )\n    }\n}\n","numLines":442,"startLine":1,"totalLines":442}},"sourceToolAssistantUUID":"bac42407-eea8-468e-a870-7e6fea7ed66f","userType":"external","entrypoint":"claude-desktop","cwd":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/Packages/MovieSwiftFluxCore","sessionId":"2cae28a4-28e8-4bfa-9225-7682543f3664","version":"2.1.149","gitBranch":"modernize/parameterize-people-actions-tests","slug":"snuggly-shimmying-pebble"}
