{"parentUuid":"c1426c35-fedd-48e8-aaec-eced6811c1ce","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/MovieSwiftUITests/MovieSwiftMacUITests.swift","snippet":"1\t//  UI tests for the native macOS target. Uses NavigationSplitView sidebar navigation.\n2\t\n3\timport XCTest\n4\timport MovieSwiftFluxCore\n5\t\n6\t// `@MainActor`: XCUIApplication / XCUIElement and waitForExpectations are\n7\t// main-actor-isolated under the Swift 6 mode; pin the case to the main\n8\t// actor (the test target is nonisolated by default).\n9\t@MainActor\n10\tfinal class MovieSwiftMacUITests: XCTestCase {\n11\t    private let timeout = UITestConstants.uiWaitTimeout\n12\t\n13\t    // Async setUp variant: main-actor-isolated without clashing with\n14\t    // XCTestCase's nonisolated sync setUpWithError.\n15\t    override func setUp() async throws {\n16\t        continueAfterFailure = false\n17\t    }\n18\t\n19\t    // MARK: - Helpers\n20\t\n21\t    /// Launch the app, optionally pre-selecting a sidebar menu via the\n22\t    /// `UI_TEST_SELECT_MENU` environment variable. This is the reliable way\n23\t    /// to navigate the sidebar in headless CI where `tap()` on SwiftUI\n24\t    /// `List(selection:)` rows does not trigger the selection binding.\n25\t    @discardableResult\n26\t    private func launchApp(\n27\t        selectMenu menu: String? = nil,\n28\t        environment: [String: String] = [:]\n29\t    ) -> XCUIApplication {\n30\t        var env = environment\n31\t        if let menu {\n32\t            env[\"UI_TEST_SELECT_MENU\"] = menu\n33\t        }\n34\t        return .launchForTesting(environment: env)\n35\t    }\n36\t\n37\t    private func waitForSidebarItem(_ title: String, in app: XCUIApplication) {\n38\t        let sidebarItem = app.identifiedElement(\"sidebar.\\(title)\")\n39\t        XCTAssertTrue(sidebarItem.waitForExistence(timeout: timeout),\n40\t                      \"Expected sidebar item '\\(title)' to exist\")\n41\t    }\n42\t\n43\t    @discardableResult\n44\t    private func openFirstMovieDetail(in app: XCUIApplication) -> XCUIElement {\n45\t        // Popular is the default selection — no sidebar tap needed\n46\t        let firstMovie = app.identifiedElement(\"moviesList.movie.0\")\n47\t        XCTAssertTrue(firstMovie.waitForExistence(timeout: timeout))\n48\t        firstMovie.tap()\n49\t\n50\t        let addToListButton = app.identifiedElement(\"movieDetail.addToListButton\")\n51\t        logHierarchyOnMissing(app, element: addToListButton, named: \"movieDetail.addToListButton\")\n52\t        XCTAssertTrue(addToListButton.waitForExistence(timeout: timeout))\n53\t        return addToListButton\n54\t    }\n55\t\n56\t    // MARK: - Launch & Navigation\n57\t\n58\t    func testLaunchShowsSidebar() {\n59\t        let app = launchApp()\n60\t\n61\t        let sidebarItems = [\"Popular\", \"Top rated\", \"Upcoming\", \"Now Playing\",\n62\t                            \"Trending\", \"Genres\", \"Fan Club\", \"Discover\",\n63\t                            \"My Lists\", \"Settings\"]\n64\t        for item in sidebarItems {\n65\t            XCTAssertTrue(\n66\t                app.identifiedElement(\"sidebar.\\(item)\").waitForExistence(timeout: timeout),\n67\t                \"Expected sidebar item '\\(item)' to exist\"\n68\t            )\n69\t        }\n70\t    }\n71\t\n72\t    func testPopularTabShowsMovies() {\n73\t        let app = launchApp(selectMenu: \"Popular\")\n74\t\n75\t        let firstMovie = app.identifiedElement(\"moviesList.movie.0\")\n76\t        XCTAssertTrue(firstMovie.waitForExistence(timeout: timeout))\n77\t    }\n78\t\n79\t    func testTopRatedTabShowsMovies() {\n80\t        let app = launchApp(selectMenu: \"Top rated\")\n81\t\n82\t        let firstMovie = app.identifiedElement(\"moviesList.movie.0\")\n83\t        XCTAssertTrue(firstMovie.waitForExistence(timeout: timeout))\n84\t    }\n85\t\n86\t    // MARK: - Movie Detail\n87\t\n88\t    func testSelectingMovieOpensDetail() {\n89\t        let app = launchApp()\n90\t        _ = openFirstMovieDetail(in: app)\n91\t    }\n92\t\n93\t    func testMovieDetailShowsGenreChips() {\n94\t        let app = launchApp()\n95\t        _ = openFirstMovieDetail(in: app)\n96\t\n97\t        let genreChip = app.identifiedButton(\"movieDetail.genre.0\")\n98\t        XCTAssertTrue(genreChip.waitForExistence(timeout: timeout))\n99\t    }\n100\t\n101\t    func testMovieDetailCanNavigateToPersonAndBack() {\n102\t        let app = launchApp()\n103\t        _ = openFirstMovieDetail(in: app)\n104\t\n105\t        let topPersonLink = app.identifiedElement(\"movieDetail.topPersonShortcut\")\n106\t        logHierarchyOnMissing(app, element: topPersonLink, named: \"movieDetail.topPersonShortcut\")\n107\t        XCTAssertTrue(topPersonLink.waitForExistence(timeout: timeout))\n108\t        topPersonLink.tap()\n109\t\n110\t        XCTAssertTrue(app.identifiedElement(\"peopleDetail.knownFor\").waitForExistence(timeout: timeout))\n111\t\n112\t        let backButton = app.buttons[\"BackButton\"]\n113\t        if backButton.waitForExistence(timeout: 2) {\n114\t            backButton.tap()\n115\t            XCTAssertTrue(app.identifiedElement(\"movieDetail.addToListButton\").waitForExistence(timeout: timeout))\n116\t        }\n117\t    }\n118\t\n119\t    func testMovieDetailWishlistButtonToggles() {\n120\t        let app = launchApp()\n121\t        _ = openFirstMovieDetail(in: app)\n122\t\n123\t        let wishlistButton = app.buttons.matching(\n124\t            NSPredicate(format: \"label == %@ OR label == %@\", \"Wishlist\", \"In wishlist\")\n125\t        ).firstMatch\n126\t        XCTAssertTrue(wishlistButton.waitForExistence(timeout: timeout))\n127\t\n128\t        let initialLabel = wishlistButton.label\n129\t        wishlistButton.tap()\n130\t\n131\t        let expectedLabel = initialLabel == \"Wishlist\" ? \"In wishlist\" : \"Wishlist\"\n132\t        let toggled = app.buttons.matching(NSPredicate(format: \"label == %@\", expectedLabel)).firstMatch\n133\t        XCTAssertTrue(toggled.waitForExistence(timeout: timeout))\n134\t    }\n135\t\n136\t    func testMovieDetailSeenlistButtonToggles() {\n137\t        let app = launchApp()\n138\t        _ = openFirstMovieDetail(in: app)\n139\t\n140\t        let seenlistButton = app.buttons.matching(\n141\t            NSPredicate(format: \"label == %@ OR label == %@\", \"Seenlist\", \"Seen\")\n142\t        ).firstMatch\n143\t        XCTAssertTrue(seenlistButton.waitForExistence(timeout: timeout))\n144\t\n145\t        let initialLabel = seenlistButton.label\n146\t        seenlistButton.tap()\n147\t\n148\t        let expectedLabel = initialLabel == \"Seenlist\" ? \"Seen\" : \"Seenlist\"\n149\t        let toggled = app.buttons.matching(NSPredicate(format: \"label == %@\", expectedLabel)).firstMatch\n150\t        XCTAssertTrue(toggled.waitForExistence(timeout: timeout))\n151\t    }\n152\t\n153\t    func testSidebarMenuChangePopsPushedMovieDetail() {\n154\t        // Regression test: clicking a different sidebar menu while a\n155\t        // MovieDetail is pushed in the right pane must pop the pushed\n156\t        // destination. NavigationSplitView on macOS used to hold on to\n157\t        // the pushed view across menu changes; SplitView now lifts the\n158\t        // navigationRoute up and nils it before swapping menus.\n159\t        let app = launchApp()\n160\t\n161\t        // Push MovieDetail from the default Popular menu.\n162\t        let addToListButton = openFirstMovieDetail(in: app)\n163\t        XCTAssertTrue(addToListButton.exists,\n164\t                      \"MovieDetail should be visible after tapping the first movie\")\n165\t\n166\t        // Switch sidebar to Top rated.\n167\t        let topRated = app.identifiedElement(\"sidebar.Top rated\")\n168\t        XCTAssertTrue(topRated.waitForExistence(timeout: timeout))\n169\t        topRated.tap()\n170\t\n171\t        // The pushed MovieDetail must be gone and the new menu's\n172\t        // movie list must be at the root.\n173\t        let detailGone = NSPredicate(format: \"exists == false\")\n174\t        let detailDismissed = expectation(for: detailGone, evaluatedWith: addToListButton)\n175\t        wait(for: [detailDismissed], timeout: timeout)\n176\t\n177\t        let firstMovie = app.identifiedElement(\"moviesList.movie.0\")\n178\t        XCTAssertTrue(firstMovie.waitForExistence(timeout: timeout),\n179\t                      \"Expected the new menu's movies list to be visible at the root\")\n180\t    }\n181\t\n182\t    func testMovieDetailGenreChipExists() {\n183\t        // Verify genre chip exists and is tappable. Full genre navigation\n184\t        // (navigationDestination push within the detail NavigationStack)\n185\t        // is unreliable in headless macOS CI, so we only verify the chip\n\n... [607 lines truncated] ..."},"type":"attachment","uuid":"243162d8-1fa2-4890-bc8a-e4ea336a1323","timestamp":"2026-05-30T02:34:18.529Z","userType":"external","entrypoint":"claude-desktop","cwd":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift","sessionId":"2cae28a4-28e8-4bfa-9225-7682543f3664","version":"2.1.149","gitBranch":"modernize/parameterize-reducer-tests","slug":"snuggly-shimmying-pebble"}
