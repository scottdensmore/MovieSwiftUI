{"parentUuid":"d38fa037-ed48-46be-a367-06ada91b4232","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/Packages/MovieSwiftFluxCore/Tests/MovieSwiftFluxCoreTests/ReducerTests.swift","snippet":"1\timport Testing\n2\t@testable import MovieSwiftFluxCore\n3\t\n4\t@Suite struct ReducerTests {\n5\t    @Test func moviesReducerSetMovieMenuListPageOneReplacesList() {\n6\t        var state = MoviesState()\n7\t        state.moviesList[.popular] = [999]\n8\t\n9\t        let response = paginated([makeMovie(id: 1), makeMovie(id: 2)])\n10\t        let action = MoviesActions.SetMovieMenuList(page: 1, list: .popular, response: response)\n11\t\n12\t        let reduced = moviesStateReducer(state: state, action: action)\n13\t\n14\t        #expect((reduced.moviesList[.popular] ?? []) == [1, 2])\n15\t        #expect(reduced.movies[1]?.id == 1)\n16\t        #expect(reduced.movies[2]?.id == 2)\n17\t    }\n18\t\n19\t    @Test func moviesReducerSetMovieMenuListPageTwoAppendsList() {\n20\t        var state = MoviesState()\n21\t        state.moviesList[.trending] = [1]\n22\t\n23\t        let response = paginated([makeMovie(id: 2), makeMovie(id: 3)])\n24\t        let action = MoviesActions.SetMovieMenuList(page: 2, list: .trending, response: response)\n25\t\n26\t        let reduced = moviesStateReducer(state: state, action: action)\n27\t\n28\t        #expect((reduced.moviesList[.trending] ?? []) == [1, 2, 3])\n29\t    }\n30\t\n31\t    @Test func moviesReducerAddToWishlistMovesMovieAndAddsMetaTimestamp() {\n32\t        var state = MoviesState()\n33\t        state.seenlist.insert(42)\n34\t\n35\t        let reduced = moviesStateReducer(state: state, action: MoviesActions.AddToWishlist(movie: 42))\n36\t\n37\t        #expect(reduced.wishlist.contains(42))\n38\t        #expect(!(reduced.seenlist.contains(42)))\n39\t        #expect(reduced.moviesUserMeta[42]?.addedToList != nil)\n40\t    }\n41\t\n42\t    @Test func moviesReducerSetRandomDiscoverPrependsWhenBelowLimit() {\n43\t        var state = MoviesState()\n44\t        state.discover = [100, 101]\n45\t        let filter = DiscoverFilter(year: 1990, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: 12, region: \"US\")\n46\t        let response = paginated([makeMovie(id: 1), makeMovie(id: 2)])\n47\t\n48\t        let reduced = moviesStateReducer(\n49\t            state: state,\n50\t            action: MoviesActions.SetRandomDiscover(filter: filter, response: response)\n51\t        )\n52\t\n53\t        #expect(reduced.discover == [1, 2, 100, 101])\n54\t        #expect(reduced.movies[1]?.id == 1)\n55\t        #expect(reduced.movies[2]?.id == 2)\n56\t        #expect(reduced.discoverFilter?.year == filter.year)\n57\t        #expect(reduced.discoverFilter?.sort == filter.sort)\n58\t        #expect(reduced.discoverFilter?.genre == filter.genre)\n59\t        #expect(reduced.discoverFilter?.region == filter.region)\n60\t    }\n61\t\n62\t    @Test func moviesReducerSetRandomDiscoverDoesNotPrependWhenAtLimit() {\n63\t        var state = MoviesState()\n64\t        state.discover = Array(1...10)\n65\t        let filter = DiscoverFilter(year: 1990, startYear: nil, endYear: nil, sort: \"popularity.desc\", genre: nil, region: nil)\n66\t        let response = paginated([makeMovie(id: 99)])\n67\t\n68\t        let reduced = moviesStateReducer(\n69\t            state: state,\n70\t            action: MoviesActions.SetRandomDiscover(filter: filter, response: response)\n71\t        )\n72\t\n73\t        #expect(reduced.discover == Array(1...10))\n74\t        #expect(reduced.movies[99]?.id == 99)\n75\t        #expect(reduced.discoverFilter?.year == 1990)\n76\t    }\n77\t\n78\t    @Test func moviesReducerSetActiveDiscoverFilterUpdatesFilterImmediately() {\n79\t        var state = MoviesState()\n80\t        state.discoverFilter = nil\n81\t        let filter = DiscoverFilter(year: 2001, startYear: 1990, endYear: 1999, sort: \"popularity.desc\", genre: 28, region: \"US\")\n82\t\n83\t        let reduced = moviesStateReducer(\n84\t            state: state,\n85\t            action: MoviesActions.SetActiveDiscoverFilter(filter: filter)\n86\t        )\n87\t\n88\t        #expect(reduced.discoverFilter?.startYear == 1990)\n89\t        #expect(reduced.discoverFilter?.endYear == 1999)\n90\t        #expect(reduced.discoverFilter?.genre == 28)\n91\t        #expect(reduced.discoverFilter?.region == \"US\")\n92\t    }\n93\t\n94\t    @Test func moviesReducerSetGenresInsertsRandomGenreFirst() {\n95\t        let genres = [Genre(id: 7, name: \"Drama\"), Genre(id: 8, name: \"Comedy\")]\n96\t\n97\t        let reduced = moviesStateReducer(state: MoviesState(), action: MoviesActions.SetGenres(genres: genres))\n98\t\n99\t        #expect(reduced.genres.first?.id == -1)\n100\t        #expect(reduced.genres.first?.name == \"Random\")\n101\t        #expect(reduced.genres.dropFirst().map(\\.id) == [7, 8])\n102\t    }\n103\t\n104\t    @Test func moviesReducerAddMoviesToCustomListMergesIntoExistingList() {\n105\t        let existing = CustomList(id: 9, name: \"Favorites\", cover: nil, movies: [1, 2])\n106\t        var state = MoviesState()\n107\t        state.customLists[9] = existing\n108\t\n109\t        let reduced = moviesStateReducer(\n110\t            state: state,\n111\t            action: MoviesActions.AddMoviesToCustomList(list: 9, movies: [2, 3, 4])\n112\t        )\n113\t\n114\t        #expect(reduced.customLists[9]?.movies == Set([1, 2, 3, 4]))\n115\t    }\n116\t\n117\t    @Test func moviesReducerEditCustomListUpdatesOnlyProvidedFields() {\n118\t        let existing = CustomList(id: 4, name: \"Weekend\", cover: 7, movies: [7, 8])\n119\t        var state = MoviesState()\n120\t        state.customLists[4] = existing\n121\t\n122\t        let renamed = moviesStateReducer(\n123\t            state: state,\n124\t            action: MoviesActions.EditCustomList(list: 4, title: \"Weeknight\", cover: nil)\n125\t        )\n126\t        #expect(renamed.customLists[4]?.name == \"Weeknight\")\n127\t        #expect(renamed.customLists[4]?.cover == 7)\n128\t\n129\t        let recoved = moviesStateReducer(\n130\t            state: renamed,\n131\t            action: MoviesActions.EditCustomList(list: 4, title: nil, cover: 11)\n132\t        )\n133\t        #expect(recoved.customLists[4]?.name == \"Weeknight\")\n134\t        #expect(recoved.customLists[4]?.cover == 11)\n135\t    }\n136\t\n137\t    @Test func peopleReducerSetDetailPreservesExistingMetadataFields() {\n138\t        let knownFor = [People.KnownFor(id: 90, original_title: \"Old\", poster_path: \"/old.jpg\")]\n139\t        let images = [ImageData(aspect_ratio: 1.0, file_path: \"/img.jpg\", height: 10, width: 10)]\n140\t\n141\t        var state = PeoplesState()\n142\t        state.peoples[5] = makePeople(id: 5, name: \"Old Name\", character: \"Old Char\", department: \"Directing\", knownFor: knownFor, images: images)\n143\t\n144\t        let incoming = makePeople(id: 5, name: \"New Name\", character: nil, department: nil, knownFor: nil, images: nil)\n145\t        let reduced = peoplesStateReducer(state: state, action: PeopleActions.SetDetail(person: incoming))\n146\t\n147\t        #expect(reduced.peoples[5]?.name == \"New Name\")\n148\t        // SetDetail only preserves known_for and images from the existing record;\n149\t        // character and department come from the incoming person as-is.\n150\t        #expect(reduced.peoples[5]?.character == nil)\n151\t        #expect(reduced.peoples[5]?.department == nil)\n152\t        #expect(reduced.peoples[5]?.known_for?.first?.id == 90)\n153\t        #expect(reduced.peoples[5]?.images?.first?.file_path == \"/img.jpg\")\n154\t    }\n155\t\n156\t    @Test func peopleReducerSetMovieCastsMergesPeopleAndIndexesMovie() {\n157\t        let cast = makePeople(id: 1, name: \"Cast Member\")\n158\t        let crew = makePeople(id: 2, name: \"Crew Member\")\n159\t        let response = CastResponse(id: 100, cast: [cast], crew: [crew])\n160\t\n161\t        let reduced = peoplesStateReducer(state: PeoplesState(), action: PeopleActions.SetMovieCasts(movie: 99, response: response))\n162\t\n163\t        #expect(reduced.peoples[1]?.name == \"Cast Member\")\n164\t        #expect(reduced.peoples[2]?.name == \"Crew Member\")\n165\t        #expect(reduced.peoplesMovies[99] == Set([1, 2]))\n166\t    }\n167\t\n168\t    @Test func peopleReducerSetPeopleCreditsStoresCharacterAndDepartmentMaps() {\n169\t        let castMovie = makeMovie(id: 10, character: \"Hero\", department: nil)\n170\t        let castMovieWithoutCharacter = makeMovie(id: 11, character: nil, department: nil)\n171\t        let crewMovie = makeMovie(id: 20, character: nil, department: \"Directing\")\n172\t        let crewMovieWithoutDepartment = makeMovie(id: 21, character: nil, department: nil)\n173\t\n\n... [462 lines truncated] ..."},"type":"attachment","uuid":"b46160b6-eda6-4b57-b1e6-9a2109df4a97","timestamp":"2026-05-30T02:47:05.335Z","userType":"external","entrypoint":"claude-desktop","cwd":"/Users/scottdensmore/Developer/scottdensmore/movieswiftui/MovieSwift/Packages/MovieSwiftFluxCore","sessionId":"2cae28a4-28e8-4bfa-9225-7682543f3664","version":"2.1.149","gitBranch":"modernize/parameterize-reducer-tests","slug":"snuggly-shimmying-pebble"}
